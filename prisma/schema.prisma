generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Identidade & acesso
// ─────────────────────────────────────────────────────────────

enum Role {
  admin
  supervisor
  administrativo
  clt
  estagiario
  projetista_pj
  freelancer
  cliente
  ti
}

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // Campos de domínio
  role               Role            @default(cliente)
  ativo              Boolean         @default(true)
  mustChangePassword Boolean         @default(false)
  chatStatus         ChatStatus      @default(disponivel)
  /// Vínculo do usuário externo (role cliente) ao Cliente que ele representa no portal.
  clienteId          String?
  cliente            Cliente?        @relation("ClienteUsuarios", fields: [clienteId], references: [id])
  /// Item 6: PJ (CNPJ) que agrupa este perfil de projetista/colaborador PJ. Opcional —
  /// vínculos existentes (NF, pagamentos, projetos) permanecem no próprio User.
  pjId               String?
  pj                 PessoaJuridica? @relation(fields: [pjId], references: [id])
  /// Salário base do colaborador CLT/estagiário (p/ geração automática de holerites).
  salarioBase        Decimal?        @db.Decimal(12, 2)
  /// Data de admissão (CLT) — base do período aquisitivo de férias.
  dataAdmissao       DateTime?

  // Item 4 — cadastro completo do colaborador (replicado do RH do sistema antigo).
  // Tipo de contrato = `role`; jornada = `EscalaRole`/`EscalaUsuario` (Ponto v2).
  // Dados pessoais
  cpf                   String?
  rg                    String?
  dataNascimento        DateTime? @db.Date
  sexo                  String? // masculino | feminino | outro | nao_informado
  estadoCivil           String? // solteiro | casado | divorciado | viuvo | uniao_estavel | outro
  nacionalidade         String?
  // Endereço / contato
  enderecoCep           String?
  enderecoLogradouro    String?
  enderecoNumero        String?
  enderecoComplemento   String?
  enderecoBairro        String?
  enderecoCidade        String?
  enderecoUf            String?
  telefone              String?
  telefoneEmergencia    String?
  contatoEmergenciaNome String?
  emailPessoal          String?
  // Dados bancários
  banco                 String?
  agencia               String?
  conta                 String?
  tipoContaBancaria     String? // corrente | poupanca | salario | pagamento
  // Profissional
  cargo                 String?
  departamento          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions          Session[]
  accounts          Account[]
  auditLogs         AuditLog[]
  resetSolicitacoes SolicitacaoResetSenha[]

  projetosMembro         ProjetoMembro[]
  disciplinasResponsavel DisciplinaResponsavel[]
  revisoes               RevisaoDisciplina[]
  uploadsAutor           Upload[]                  @relation("UploadAutor")
  uploadsValidados       Upload[]                  @relation("UploadValidador")
  uploadsRevisados       Upload[]                  @relation("UploadRevisor")
  documentosAutor        Documento[]               @relation("DocumentoAutor")
  pagamentos             PagamentoProjetista[]     @relation("PagamentoProjetista")
  socio                  Socio?
  lancamentosAutor       Lancamento[]              @relation("LancamentoAutor")
  importacoesFinanceiras ImportacaoFinanceira[]    @relation("ImportacaoFinanceiraAutor")
  canaisMembro           CanalMembro[]
  canaisCriados          Canal[]                   @relation("CanaisCriados")
  mensagens              Mensagem[]
  sessoes                SessaoTrabalho[]
  batidas                Batida[]
  batidasAjustadas       Batida[]                  @relation("BatidaCriador")
  escalasUsuario         EscalaUsuario[]
  espelhoAceites         EspelhoAceite[]
  ajustesPonto           AjustePonto[]             @relation("AjustePontoUsuario")
  ajustesPontoEditados   AjustePonto[]             @relation("AjustePontoEditor")
  alertasPontoEnviados   AlertaPontoEnviado[]
  abonos                 AbonoFalta[]              @relation("AbonoUser")
  abonosValidados        AbonoFalta[]              @relation("AbonoValidador")
  ferias                 Ferias[]                  @relation("FeriasUser")
  feriasValidadas        Ferias[]                  @relation("FeriasValidador")
  emocoes                RegistroEmocao[]
  feedbacksHumor         FeedbackHumor[]
  holerites              Holerite[]
  onboarding             OnboardingProcesso?
  notasFiscais           NotaFiscalPJ[]            @relation("NfUser")
  nfsValidadas           NotaFiscalPJ[]            @relation("NfValidador")
  documentoVersoes       DocumentoModeloVersao[]
  atividadesLead         AtividadeLead[]
  propostasAutor         Proposta[]                @relation("PropostaAutor")
  propostaVersoes        PropostaVersao[]          @relation("PropostaVersaoAutor")
  tarefasCriadas         Tarefa[]                  @relation("TarefaCriador")
  tarefasResponsavel     TarefaResponsavel[]
  docJuridicoVersoes     DocJuridicoVersao[]
  docLicitacaoVersoes    DocLicitacaoVersao[]
  compromissosCriados    Compromisso[]             @relation("CompromissoCriador")
  compromissosConvites   CompromissoParticipante[]
  ticketsAutor           TicketSuporte[]           @relation("TicketAutor")
  ticketMensagens        TicketMensagem[]          @relation("TicketMensagemAutor")
  recurso                Recurso?
  dependentes            Dependente[]
  tarefaComentarios      TarefaComentario[]        @relation("TarefaComentarioAutor")
  habilidades            UserHabilidade[]
  rateios                RateioHora[]
  funcDocumentos         FuncionarioDocumento[]    @relation("FuncDocumentos")
  bancoHoras             BancoHorasMensal[]
  feedbacksRecebidos     FeedbackRH[]              @relation("FeedbackAlvo")
  mensagensLidas         MensagemLeitura[]
  reacoes                MensagemReacao[]
  preference             UserPreference?
  planejamentos          PlanejamentoPagamento[]
  fechamentos            FechamentoMensal[]
  responsavelTecnico     ResponsavelTecnico?
  viabilidadesDecididas  ViabilidadeLicitacao[]    @relation("ViabilidadeDecisor")
  aceitesGerados         AceiteCliente[]           @relation("AceiteGerador")
  calculosFerramenta     CalculoFerramenta[]
  aceitesTermo           AceiteTermo[]
  ativosResponsavel      Ativo[]                   @relation("AtivoResponsavel")
  maquinasResponsavel    MaquinaTI[]               @relation("MaquinaResponsavel")

  @@index([role])
  @@map("user")
}

enum TipoTermo {
  colaborador
  cliente
}

/// Registro append-only do aceite do Termo de Uso por usuário/tipo/versão.
/// Prova legal da manifestação: versão aceita, data/hora, IP, user-agent e
/// hash SHA-256 do conteúdo exibido (não-repúdio mesmo que o texto mude depois).
/// O texto e a versão vigente vivem em src/modules/legal/termos.ts.
model AceiteTermo {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo         TipoTermo
  versao       String
  conteudoHash String
  ip           String?
  userAgent    String?
  aceitoEm     DateTime  @default(now())

  @@unique([userId, tipo, versao])
  @@index([userId, tipo])
  @@map("aceite_termo")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Pedido de reset de senha (admin reinicia pela tela de usuários).
model SolicitacaoResetSenha {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resolvida Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolvida])
  @@map("solicitacao_reset_senha")
}

// ─────────────────────────────────────────────────────────────
// Permissões finas (recurso:ação), configuráveis em runtime
// ─────────────────────────────────────────────────────────────

model Permissao {
  id        String  @id @default(cuid())
  role      Role
  recurso   String
  acao      String
  permitido Boolean @default(true)

  @@unique([role, recurso, acao])
  @@index([role])
  @@map("permissao")
}

// ─────────────────────────────────────────────────────────────
// Auditoria (registro imutável de toda mutação)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  modulo     String
  acao       String
  tipo       String   @default("acao") // acao | login | erro
  resultado  String   @default("sucesso") // sucesso | falha | bloqueado
  entidade   String?
  entidadeId String?
  detalhe    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([modulo])
  @@index([createdAt])
  @@map("audit_log")
}

/// Registro de acesso (page-view) a uma seção, para a análise de uso (admin).
/// Dado interno de colaboradores; `userId` escalar (sem relação). Alimentado
/// pelo beacon de navegação do dashboard. Complementa o AuditLog (que mede ações).
model AcessoPagina {
  id        String   @id @default(cuid())
  userId    String
  secao     String
  path      String
  createdAt DateTime @default(now())

  @@index([secao, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@map("acesso_pagina")
}

// ─────────────────────────────────────────────────────────────
// Notificações (sininho interno) + Web Push
// ─────────────────────────────────────────────────────────────

model Notificacao {
  id        String   @id @default(cuid())
  userId    String
  titulo    String
  corpo     String?
  href      String?
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lida])
  @@map("notificacao")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscription")
}

// ─────────────────────────────────────────────────────────────
// Configuração geral do sistema (chave/valor)
// ─────────────────────────────────────────────────────────────

model ConfigSistema {
  chave     String   @id
  valor     Json
  updatedAt DateTime @updatedAt

  @@map("config_sistema")
}

// ─────────────────────────────────────────────────────────────
// Clientes (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoPessoa {
  PF
  PJ
}

model Cliente {
  id           String     @id @default(cuid())
  tipo         TipoPessoa @default(PJ)
  nome         String // nome (PF) ou razão social (PJ)
  nomeFantasia String?
  documento    String? // CPF ou CNPJ
  email        String?
  telefone     String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?

  observacoes String?
  /// Classificação livre do cliente (ex.: porte/segmento), p/ filtro e relatório.
  categoria   String?
  ativo       Boolean @default(true)

  // Login externo opcional do cliente (criado sob demanda).
  usuarioId String? @unique

  contatos      ContatoCliente[]
  projetos      Projeto[]
  lancamentos   Lancamento[]
  leads         Lead[]
  propostas     Proposta[]
  usuarios      User[]              @relation("ClienteUsuarios")
  docsJuridicos DocumentoJuridico[]
  documentos    Documento[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([ativo])
  @@index([nome])
  @@map("cliente")
}

model ContatoCliente {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nome      String
  cargo     String?
  email     String?
  telefone  String?
  principal Boolean @default(false)

  @@index([clienteId])
  @@map("contato_cliente")
}

// ─────────────────────────────────────────────────────────────
// Projetos & Disciplinas (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoProjeto {
  particular
  licitacao
  /// Item 16 (beta): projeto de aprovação (só protocolo/aprovação em órgão, sem execução).
  aprovacao
}

enum SituacaoProjeto {
  em_andamento
  concluido
  arquivado
  cancelado
}

enum StatusDisciplina {
  aguardando
  em_andamento
  em_revisao
  entregue
  aprovado
}

/// Catálogo configurável de disciplinas (Estrutural, Hidráulica…).
model DisciplinaCatalogo {
  id        String  @id @default(cuid())
  nome      String  @unique
  /// Sigla usada na nomenclatura de arquivos (ex.: ELE, ARQ). Opcional/única.
  codigo    String? @unique
  /// Grupo de exibição no catálogo (CIVIL, ELÉTRICA…). null = "Outras".
  categoria String?
  /// Chave da galeria de ícones (lucide, ex.: "Zap"). null = derivar do nome.
  icone     String?
  /// SVG custom já sanitizado (upload). Precede `icone` na resolução do ícone.
  iconeSvg  String?
  ativo     Boolean @default(true)
  ordem     Int     @default(0)

  @@map("disciplina_catalogo")
}

/// Sequência atômica do número AAXXXX por ano.
model ProjetoSequencia {
  ano    Int @id
  ultimo Int @default(0)

  @@map("projeto_sequencia")
}

model Projeto {
  id            String          @id @default(cuid())
  ano           Int
  sequencial    Int
  /// Código de exibição AAXXXX (ex.: 260142).
  codigo        String          @unique
  tipo          TipoProjeto     @default(particular)
  situacao      SituacaoProjeto @default(em_andamento)
  nome          String
  descricao     String?
  clienteId     String
  cliente       Cliente         @relation(fields: [clienteId], references: [id])
  areaM2        Decimal?        @db.Decimal(12, 2)
  endereco      String?
  prazoFinal    DateTime?
  /// Valor de contrato (referência de receita). Base para gerar parcelas/recebíveis.
  valorContrato Decimal?        @db.Decimal(14, 2)

  disciplinas        Disciplina[]
  membros            ProjetoMembro[]
  inputs             InputProjeto[]
  briefing           BriefingProjeto?
  linkInput          LinkPublicoInput?
  lancamentos        Lancamento[]
  canais             Canal[]
  proposta           Proposta?
  tarefas            Tarefa[]
  docsJuridicos      DocumentoJuridico[]
  documentos         Documento[]
  licitacao          Licitacao?
  sessoes            SessaoTrabalho[]
  eapTarefas         EapTarefa[]
  alocacoes          Alocacao[]
  servicos           ServicoTerceirizado[]
  rateios            RateioHora[]
  composicaoPreco    ProjetoComposicaoPreco?
  lmConfig           LmConfig?
  pranchaCatalogos   PranchaCatalogo[]
  nomenclaturaConfig NomenclaturaConfig?
  linhasBase         LinhaBase[]
  planejamentos      PlanejamentoPagamento[]
  checklist          ChecklistItemProjeto[]
  riscos             RiscoProjeto[]
  calculosFerramenta CalculoFerramenta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ano, sequencial])
  @@index([clienteId])
  @@index([situacao])
  @@map("projeto")
}

/// N-34: item de checklist livre por projeto.
model ChecklistItemProjeto {
  id          String    @id @default(cuid())
  projetoId   String
  descricao   String
  concluido   Boolean   @default(false)
  concluidoEm DateTime?
  ordem       Int       @default(0)
  createdAt   DateTime  @default(now())

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId])
  @@map("checklist_item_projeto")
}

/// N-39: risco identificado para um projeto.
model RiscoProjeto {
  id            String   @id @default(cuid())
  projetoId     String
  descricao     String
  probabilidade Int      @default(1) // 1=baixa 2=média 3=alta
  impacto       Int      @default(1) // 1=baixo 2=médio 3=alto
  mitigacao     String?
  status        String   @default("aberto") // aberto | mitigado | aceito
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId])
  @@map("risco_projeto")
}

/// Campo de input do projeto (pergunta + resposta do cliente).
/// Pergunta padrão de input por disciplina (template), aplicada automaticamente aos projetos (#3).
model InputTemplate {
  id         String   @id @default(cuid())
  disciplina String? // null = geral; senão nome da disciplina (DisciplinaCatalogo)
  pergunta   String
  ordem      Int      @default(0)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([disciplina])
  @@map("input_template")
}

model InputProjeto {
  id         String   @id @default(cuid())
  projetoId  String
  projeto    Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplina String? // null = geral; senão nome da disciplina
  pergunta   String
  resposta   String?
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projetoId])
  @@map("input_projeto")
}

/// Briefing de Start (Mód 3): respostas do formulário multi-etapas (schema em
/// modules/inputs/briefing-schema.ts). 1:1 com o projeto; respostas como JSON.
model BriefingProjeto {
  id            String    @id @default(cuid())
  projetoId     String    @unique
  projeto       Projeto   @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  respostasJson Json      @default("{}")
  /// nao_iniciado | em_preenchimento | completo (derivado, persistido p/ listagem rápida).
  status        String    @default("nao_iniciado")
  preenchidoPor String?
  preenchidoEm  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("briefing_projeto")
}

/// Link público (por token) para o cliente preencher os inputs sem login.
model LinkPublicoInput {
  id        String   @id @default(cuid())
  projetoId String   @unique
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  token     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("link_publico_input")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Cadastros base (Onda 2a)
// ─────────────────────────────────────────────────────────────

enum TipoCategoria {
  receita
  despesa
}

/// Plano de contas hierárquico (código ex.: "2.01").
model CategoriaFinanceira {
  id       String                @id @default(cuid())
  codigo   String                @unique
  nome     String
  tipo     TipoCategoria
  paiId    String?
  pai      CategoriaFinanceira?  @relation("CategoriaFilhas", fields: [paiId], references: [id])
  filhas   CategoriaFinanceira[] @relation("CategoriaFilhas")
  ordem    Int                   @default(0)
  ativo    Boolean               @default(true)
  /// Atividade no DFC: "operacional" | "investimento" | "financiamento" (default operacional).
  grupoDfc String?

  lancamentos Lancamento[]
  regras      RegraCategorizacao[]
  orcamentos  OrcamentoItem[]

  @@index([tipo, ativo])
  @@map("categoria_financeira")
}

/// Valor orçado (planejado) de uma categoria para um ano — base do orçamento editável.
model OrcamentoItem {
  id             String              @id @default(cuid())
  ano            Int
  categoriaId    String
  categoria      CategoriaFinanceira @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  valorPlanejado Decimal             @db.Decimal(14, 2)
  updatedAt      DateTime            @updatedAt

  @@unique([ano, categoriaId])
  @@index([ano])
  @@map("orcamento_item")
}

model CentroCusto {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos   Lancamento[]
  planejamentos PlanejamentoPagamento[]

  @@map("centro_custo")
}

enum TipoContaBancaria {
  corrente
  poupanca
  caixa
  investimento
}

model ContaBancaria {
  id           String            @id @default(cuid())
  nome         String
  tipo         TipoContaBancaria @default(corrente)
  banco        String?
  agencia      String?
  numero       String?
  saldoInicial Decimal           @default(0) @db.Decimal(14, 2)
  padrao       Boolean           @default(false)
  ativo        Boolean           @default(true)
  ordem        Int               @default(0)

  lancamentos   Lancamento[]
  extratos      ExtratoBancario[]
  transacoes    TransacaoBancaria[]
  planejamentos PlanejamentoPagamento[]

  @@map("conta_bancaria")
}

model FormaPagamento {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos Lancamento[]

  @@map("forma_pagamento")
}

model Fornecedor {
  id          String     @id @default(cuid())
  tipo        TipoPessoa @default(PJ)
  nome        String
  documento   String?
  email       String?
  telefone    String?
  /// Tipo de serviço (topografia, sondagem, ensaios…)
  servico     String?
  observacoes String?
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lancamentos     Lancamento[]
  servicos        ServicoTerceirizado[]
  catalogo        FornecedorServico[]
  subcontratacoes SubcontratacaoLicitacao[]
  sancoes         SancaoConcorrente[]

  @@index([ativo])
  @@map("fornecedor")
}

/// Serviço que um fornecedor presta (catálogo) — com valor de referência (A7).
model FornecedorServico {
  id              String     @id @default(cuid())
  fornecedorId    String
  fornecedor      Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  descricao       String
  valorReferencia Decimal?   @db.Decimal(14, 2)
  ativo           Boolean    @default(true)
  createdAt       DateTime   @default(now())

  @@index([fornecedorId])
  @@map("fornecedor_servico")
}

model Socio {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  percentual Decimal  @db.Decimal(5, 2)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  retiradas RetiradaSocio[]

  @@map("socio")
}

/// Item 6: Pessoa Jurídica (CNPJ) que agrupa N perfis de projetista/colaborador PJ.
/// Aditivo e não-destrutivo: nenhuma relação existente (faturamento via NotaFiscalPJ,
/// pagamentos, membros de projeto) muda — todas continuam ancoradas no User.
model PessoaJuridica {
  id           String   @id @default(cuid())
  cnpj         String   @unique
  razaoSocial  String
  nomeFantasia String?
  email        String?
  telefone     String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membros User[]

  @@map("pessoa_juridica")
}

enum TipoRetiradaSocio {
  pro_labore
  distribuicao
  adiantamento
}

/// Retirada de sócio (pró-labore, distribuição de lucro, adiantamento).
model RetiradaSocio {
  id         String            @id @default(cuid())
  socioId    String
  socio      Socio             @relation(fields: [socioId], references: [id], onDelete: Cascade)
  data       DateTime          @db.Date
  valor      Decimal           @db.Decimal(14, 2)
  tipo       TipoRetiradaSocio @default(pro_labore)
  observacao String?
  createdAt  DateTime          @default(now())

  @@index([socioId])
  @@map("retirada_socio")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Lançamentos (ledger) + contas a pagar/receber (Onda 2b)
// ─────────────────────────────────────────────────────────────

enum TipoLancamento {
  receita
  despesa
}

enum StatusLancamento {
  previsto // conta a pagar/receber em aberto
  aguardando_aprovacao // despesa acima da alçada, trava até aprovação
  confirmado // pago/recebido (entra no caixa e na DRE)
  cancelado
}

/// Lançamento financeiro. previsto = conta a pagar/receber; confirmado = realizado.
model Lancamento {
  id           String           @id @default(cuid())
  tipo         TipoLancamento
  descricao    String
  valor        Decimal          @db.Decimal(14, 2)
  /// Valor efetivamente pago/recebido (parcial). Se null, considera `valor`.
  valorEfetivo Decimal?         @db.Decimal(14, 2)
  status       StatusLancamento @default(previsto)

  /// Competência/realização. `vencimento` para previstos; `dataConfirmacao` ao realizar.
  data            DateTime  @db.Date
  vencimento      DateTime? @db.Date
  dataConfirmacao DateTime? @db.Date
  /// Data de competência (regime de competência). Se null, usa `data`.
  dataCompetencia DateTime? @db.Date

  categoriaId  String
  categoria    CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  centroId     String?
  centro       CentroCusto?        @relation(fields: [centroId], references: [id])
  contaId      String?
  conta        ContaBancaria?      @relation(fields: [contaId], references: [id])
  formaId      String?
  forma        FormaPagamento?     @relation(fields: [formaId], references: [id])
  projetoId    String?
  projeto      Projeto?            @relation(fields: [projetoId], references: [id])
  fornecedorId String?
  fornecedor   Fornecedor?         @relation(fields: [fornecedorId], references: [id])
  clienteId    String?
  cliente      Cliente?            @relation(fields: [clienteId], references: [id])

  observacao            String?
  recorrenciaGrupo      String?
  /// Etiquetas livres (A6).
  tags                  String[]                    @default([])
  /// Documento-fonte (NF/contrato/proposta/medição) — rastreabilidade de origem (Fase 2).
  documentoFinanceiroId String?
  documentoFinanceiro   DocumentoFinanceiro?        @relation(fields: [documentoFinanceiroId], references: [id], onDelete: SetNull)
  anexos                LancamentoAnexo[]
  statusHistorico       LancamentoStatusHistorico[]
  planejamentoLinhas    PlanejamentoLinha[]
  /// Aprovação por alçada (Fase 4): quem aprovou, quando, e motivo se rejeitado.
  aprovadoPorId         String?
  aprovadoEm            DateTime?
  motivoRejeicao        String?
  /// Vínculo com a folha de projetistas (Onda 2c).
  pagamentoProjetistaId String?                     @unique

  autorId String
  autor   User   @relation("LancamentoAutor", fields: [autorId], references: [id])

  transacao TransacaoBancaria?

  /// Migração de dados externos (ex.: "Meu Dinheiro"). `importLoteId` agrupa o lote (undo);
  /// `importHash` (sha256 de tipo|data|valor|descrição|categoria) evita reimportar a mesma linha.
  importLoteId String?
  importLote   ImportacaoFinanceira? @relation(fields: [importLoteId], references: [id], onDelete: SetNull)
  importHash   String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Soft delete: quando preenchido, o lançamento foi excluído e some de listagens/relatórios.
  excluidoEm DateTime?

  @@index([tipo, status])
  @@index([vencimento])
  @@index([data])
  @@index([projetoId])
  @@index([excluidoEm])
  @@index([documentoFinanceiroId])
  @@index([importLoteId])
  @@index([importHash])
  @@map("lancamento")
}

/// Lote de importação financeira (migração de ERP externo). Guarda contagens por tipo,
/// o mapeamento aplicado (snapshot p/ auditoria) e permite desfazer (deleteMany por lote).
model ImportacaoFinanceira {
  id                  String       @id @default(cuid())
  nomeArquivo         String
  origem              String       @default("meu_dinheiro")
  totalLinhas         Int
  lancamentosCriados  Int          @default(0)
  categoriasCriadas   Int          @default(0)
  contasCriadas       Int          @default(0)
  formasCriadas       Int          @default(0)
  centrosCriados      Int          @default(0)
  fornecedoresCriados Int          @default(0)
  clientesCriados     Int          @default(0)
  mapeamento          Json
  autorId             String
  autor               User         @relation("ImportacaoFinanceiraAutor", fields: [autorId], references: [id])
  desfeitoEm          DateTime?
  createdAt           DateTime     @default(now())
  lancamentos         Lancamento[]

  @@index([autorId])
  @@map("importacao_financeira")
}

enum TipoDocumentoFinanceiro {
  nf_entrada
  nf_servico
  contrato
  proposta
  medicao
}

/// Documento-fonte de movimentações financeiras (rastreabilidade + parcelamento). Fase 2.
/// Híbrido: modelo próprio p/ NF/contrato; `referenciaId` reaproveita Proposta/Medição existentes.
model DocumentoFinanceiro {
  id             String                  @id @default(cuid())
  tipo           TipoDocumentoFinanceiro
  numero         String?
  dataEmissao    DateTime?               @db.Date
  valorDocumento Decimal?                @db.Decimal(14, 2)
  /// FKs escalares (sem relação, resolvidos por lookup) p/ não inflar Fornecedor/Cliente.
  fornecedorId   String?
  clienteId      String?
  /// Quando tipo = proposta|medicao: id da Proposta/MedicaoLicitacao reaproveitada (ref. soft).
  referenciaId   String?
  arquivoPath    String?
  arquivoNome    String?
  arquivoMime    String?
  observacao     String?
  autorId        String
  createdAt      DateTime                @default(now())

  lancamentos Lancamento[]

  @@index([tipo])
  @@map("documento_financeiro")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Conciliação bancária (OFX) (Onda 2d)
// ─────────────────────────────────────────────────────────────

model ExtratoBancario {
  id          String              @id @default(cuid())
  contaId     String
  conta       ContaBancaria       @relation(fields: [contaId], references: [id])
  nomeArquivo String?
  importadoEm DateTime            @default(now())
  transacoes  TransacaoBancaria[]

  @@index([contaId])
  @@map("extrato_bancario")
}

model TransacaoBancaria {
  id           String          @id @default(cuid())
  extratoId    String
  extrato      ExtratoBancario @relation(fields: [extratoId], references: [id], onDelete: Cascade)
  contaId      String
  conta        ContaBancaria   @relation(fields: [contaId], references: [id])
  /// Identificador único da transação no OFX (dedup).
  fitid        String
  data         DateTime        @db.Date
  /// Positivo = entrada, negativo = saída.
  valor        Decimal         @db.Decimal(14, 2)
  descricao    String
  conciliado   Boolean         @default(false)
  /// Lançamento ao qual esta transação foi conciliada.
  lancamentoId String?         @unique
  lancamento   Lancamento?     @relation(fields: [lancamentoId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contaId, fitid])
  @@index([contaId, conciliado])
  @@map("transacao_bancaria")
}

/// Regra de auto-categorização: descrição que casa → categoria sugerida.
model RegraCategorizacao {
  id          String              @id @default(cuid())
  termo       String
  categoriaId String
  categoria   CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  ativo       Boolean             @default(true)

  @@map("regra_categorizacao")
}

// ─────────────────────────────────────────────────────────────
// Chat interno (Onda 3a)
// ─────────────────────────────────────────────────────────────

enum TipoCanal {
  geral
  projeto
  disciplina
  dm
  grupo
  socios
}

enum ChatStatus {
  disponivel
  ocupado
  reuniao
}

model Canal {
  id           String      @id @default(cuid())
  tipo         TipoCanal
  nome         String?
  icone        String? // emoji da galeria (capa quando não há imagem)
  imagemCapa   String? // caminho relativo da imagem de capa (storage)
  criadoPorId  String?
  criadoPor    User?       @relation("CanaisCriados", fields: [criadoPorId], references: [id], onDelete: SetNull)
  projetoId    String?
  projeto      Projeto?    @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplinaId String?
  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  membros   CanalMembro[]
  mensagens Mensagem[]
  createdAt DateTime      @default(now())

  @@index([tipo])
  @@index([projetoId])
  @@index([disciplinaId])
  @@index([criadoPorId])
  @@map("canal")
}

model CanalMembro {
  id         String    @id @default(cuid())
  canalId    String
  canal      Canal     @relation(fields: [canalId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  silenciado Boolean   @default(false)

  @@unique([canalId, userId])
  @@index([userId])
  @@map("canal_membro")
}

model Mensagem {
  id          String            @id @default(cuid())
  canalId     String
  canal       Canal             @relation(fields: [canalId], references: [id], onDelete: Cascade)
  autorId     String
  autor       User              @relation(fields: [autorId], references: [id])
  conteudo    String
  fixada      Boolean           @default(false)
  encaminhada Boolean           @default(false)
  anexoPath   String?
  anexoNome   String?
  anexoMime   String?
  createdAt   DateTime          @default(now())
  editedAt    DateTime?
  excluidaEm  DateTime?
  respostaAId String?
  respostaA   Mensagem?         @relation("MensagemResposta", fields: [respostaAId], references: [id], onDelete: SetNull)
  respostas   Mensagem[]        @relation("MensagemResposta")
  leituras    MensagemLeitura[]
  reacoes     MensagemReacao[]
  anexos      MensagemAnexo[]

  @@index([canalId, createdAt])
  @@index([respostaAId])
  @@map("mensagem")
}

/// Anexo de mensagem de chat — permite múltiplos arquivos por mensagem (colar/anexar vários).
/// As colunas legadas anexoPath/Nome/Mime em Mensagem seguem para mensagens antigas (fallback).
model MensagemAnexo {
  id         String   @id @default(cuid())
  mensagemId String
  mensagem   Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  path       String
  nome       String
  mime       String
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([mensagemId])
  @@map("mensagem_anexo")
}

/// Confirmação de leitura de uma mensagem por um usuário (E6).
model MensagemLeitura {
  id         String   @id @default(cuid())
  mensagemId String
  mensagem   Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lidaEm     DateTime @default(now())

  @@unique([mensagemId, userId])
  @@index([mensagemId])
  @@map("mensagem_leitura")
}

model MensagemReacao {
  id         String   @id @default(cuid())
  mensagemId String
  mensagem   Mensagem @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji      String
  createdAt  DateTime @default(now())

  @@unique([mensagemId, userId, emoji])
  @@index([mensagemId])
  @@map("mensagem_reacao")
}

/// Biblioteca de modelos de contrato (texto base) (E2).
model ModeloContrato {
  id        String   @id @default(cuid())
  nome      String
  categoria String?
  conteudo  String   @default("")
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modelo_contrato")
}

enum StatusSolicCadastro {
  pendente
  aprovada
  recusada
}

/// Pedido público de cadastro (auto-cadastro → admin aprova) (E7).
model SolicitacaoCadastro {
  id        String              @id @default(cuid())
  nome      String
  email     String
  telefone  String?
  mensagem  String?
  status    StatusSolicCadastro @default(pendente)
  createdAt DateTime            @default(now())

  @@index([status])
  @@map("solicitacao_cadastro")
}

/// Preferências do usuário (store dedicado, key-value em JSON) (E8).
model UserPreference {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dados     Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("user_preference")
}

// ─────────────────────────────────────────────────────────────
// RH — Ponto, banco de horas, rateio (Onda 3b)
// ─────────────────────────────────────────────────────────────

/// Uma sessão de trabalho (cronômetro). fim=null = em andamento.
/// Troca de projeto fecha a sessão atual e abre outra → tempo por projeto.
model SessaoTrabalho {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projetoId String?
  projeto   Projeto?  @relation(fields: [projetoId], references: [id])
  inicio    DateTime
  fim       DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, inicio])
  @@index([projetoId])
  @@map("sessao_trabalho")
}

// EscalaTrabalho removido em F7 — substituído por EscalaRole + EscalaUsuario (Ponto v2)

/// Rateio mensal do custo de horas trabalhadas por projeto (Fluxo C: ponto → custo → margem).
/// Snapshot fechado por mês: congela o custo/hora vigente no momento do fechamento.
model RateioHora {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projetoId String
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  ano       Int
  mes       Int
  minutos   Int
  /// Custo/hora usado no fechamento (snapshot de Recurso.custoHora ou derivado do salário base).
  custoHora Decimal  @db.Decimal(10, 2)
  /// Custo total rateado = minutos / 60 × custoHora.
  custo     Decimal  @db.Decimal(12, 2)
  fechadoEm DateTime @default(now())

  @@unique([userId, projetoId, ano, mes])
  @@index([projetoId, ano, mes])
  @@map("rateio_hora")
}

/// Fechamento mensal do banco de horas: congela saldo do mês e o acumulado (carry-forward).
model BancoHorasMensal {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ano              Int
  mes              Int
  /// Saldo do mês (trabalhado − esperado), em minutos.
  saldoMinutos     Int
  /// Saldo acumulado até este mês (carry-forward), em minutos.
  acumuladoMinutos Int
  fechadoEm        DateTime @default(now())

  @@unique([userId, ano, mes])
  @@index([userId])
  @@map("banco_horas_mensal")
}

// ─────────────────────────────────────────────────────────────
// Ponto v2 — jornada por batidas, escalas, espelho, ajustes e alertas
// (jul/2026). Aditivo: SessaoTrabalho segue existindo (rateio por projeto +
// fallback histórico); Batida passa a ser a fonte de verdade da JORNADA;
// EscalaTrabalho removida (substituída por EscalaRole/EscalaUsuario em F7).
// Ver docs/superpowers/plans/... (plano "Ponto v2").
// ─────────────────────────────────────────────────────────────

enum TipoBatidaPonto {
  entrada
  inicio_descanso
  fim_descanso
  saida
}

enum OrigemBatida {
  app
  offline
  ajuste_proprio
  ajuste_admin
  migracao
}

/// Batida de ponto: fonte de verdade da jornada do dia (entrada → N descansos
/// → saída). Acoplada 1:1 à SessaoTrabalho no mesmo instante (ver service.ts) —
/// a batida não substitui a sessão, que continua alimentando o rateio por projeto.
model Batida {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Dia LOCAL (America/Sao_Paulo) da jornada — o dia da ENTRADA; jornada
  /// noturna que cruza a meia-noite permanece no dia em que começou.
  dia     DateTime        @db.Date
  tipo    TipoBatidaPonto
  /// Instante real da batida.
  horario DateTime

  /// Projeto ativo no momento da batida — informativo, sem relação (mesmo
  /// padrão de DocumentoFinanceiro.fornecedorId/clienteId: FK escalar por lookup,
  /// para não inflar o model Projeto).
  projetoId String?

  origem          OrigemBatida @default(app)
  editada         Boolean      @default(false)
  /// Snapshot do horário original — preenchido na 1ª edição (auditoria).
  horarioOriginal DateTime?
  /// Quem efetivamente registrou a batida, quando ≠ userId (ajuste do admin).
  criadoPorId     String?
  criadoPor       User?        @relation("BatidaCriador", fields: [criadoPorId], references: [id])
  /// Geolocalização opcional capturada no momento da batida (S6) — auditoria, não bloqueia.
  geo             Json?

  createdAt DateTime @default(now())

  @@index([userId, dia])
  @@index([userId, horario])
  @@map("batida")
}

/// Escala de trabalho padrão por role — uma linha por dia da semana (0=domingo
/// .. 6=sábado). Resolução: EscalaUsuario ativa (override) → EscalaRole do
/// role → fallback seg-sex 8h sem horários.
model EscalaRole {
  id        String @id @default(cuid())
  role      Role
  diaSemana Int

  /// Horário previsto "HH:MM" — null = day off / sem horário fixo.
  entrada       String?
  saida         String?
  /// Descansos previstos: `[{inicio,fim}]` em "HH:MM" — múltiplos permitidos.
  descansos     Json    @default("[]")
  horasDia      Decimal @default(8) @db.Decimal(4, 2)
  ativo         Boolean @default(true)
  /// Tolerância de atraso em minutos (CLT art. 58 §1º) — informativo (S3), não altera falta/ok.
  toleranciaMin Int     @default(10)

  @@unique([role, diaSemana])
  @@map("escala_role")
}

/// Override de escala por usuário — mesma grade da EscalaRole. Se o usuário
/// tem qualquer linha ativa, a grade dele substitui a do role POR INTEIRO
/// (não mescla dia a dia).
model EscalaUsuario {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  diaSemana Int

  entrada       String?
  saida         String?
  descansos     Json    @default("[]")
  horasDia      Decimal @default(8) @db.Decimal(4, 2)
  ativo         Boolean @default(true)
  toleranciaMin Int     @default(10)

  @@unique([userId, diaSemana])
  @@map("escala_usuario")
}

/// "Assinatura" mensal do espelho de ponto pelo colaborador (S2) — mesmo
/// padrão do AceiteTermo: hash SHA-256 do conteúdo aceito prova o não-repúdio.
model EspelhoAceite {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ano      Int
  mes      Int
  hash     String
  aceitoEm DateTime @default(now())

  @@unique([userId, ano, mes])
  @@map("espelho_aceite")
}

enum StatusAjustePonto {
  pendente_ciencia
  ciente
  contestado
}

/// Evento de edição de um DIA de ponto: snapshot antes/depois + workflow de
/// ciência. Edição própria (`proprio=true`) dispensa ciência; edição do admin
/// exige que o usuário afetado confirme ou conteste.
model AjustePonto {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation("AjustePontoUsuario", fields: [userId], references: [id], onDelete: Cascade)
  editorId String
  editor   User     @relation("AjustePontoEditor", fields: [editorId], references: [id])
  dia      DateTime @db.Date

  /// Motivo obrigatório (mín. 5 caracteres — validado no schema Zod).
  justificativa  String
  /// Snapshot das batidas do dia ANTES da edição.
  snapshotAntes  Json
  /// Snapshot das batidas do dia DEPOIS da edição.
  snapshotDepois Json
  /// true = o próprio usuário editou (sem workflow de ciência).
  proprio        Boolean @default(false)

  status            StatusAjustePonto?
  cienciaEm         DateTime?
  contestacaoMotivo String?

  createdAt DateTime @default(now())

  @@index([userId, dia])
  @@index([status])
  @@map("ajuste_ponto")
}

/// Dedup de alertas de jornada já enviados — evita reenviar o mesmo alerta em
/// ticks sucessivos do job (roda a cada 5 minutos).
model AlertaPontoEnviado {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dia       DateTime @db.Date
  /// Chave do alerta: "entrada:prox", "saida:agora", "jornada_cumprida"…
  chave     String
  enviadoEm DateTime @default(now())

  @@unique([userId, dia, chave])
  @@map("alerta_ponto_enviado")
}

// ─────────────────────────────────────────────────────────────
// RH — Abono, férias, clima (Onda 3c)
// ─────────────────────────────────────────────────────────────

enum StatusSolicitacao {
  pendente
  aprovado
  rejeitado
}

/// Abono de faltas via atestado. Supervisor/RH valida.
model AbonoFalta {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation("AbonoUser", fields: [userId], references: [id], onDelete: Cascade)
  dataInicio    DateTime          @db.Date
  dataFim       DateTime          @db.Date
  motivo        String?
  atestadoPath  String?
  atestadoNome  String?
  status        StatusSolicitacao @default(pendente)
  validadoPorId String?
  validadoPor   User?             @relation("AbonoValidador", fields: [validadoPorId], references: [id])
  validadoEm    DateTime?
  createdAt     DateTime          @default(now())

  @@index([userId])
  @@index([status])
  @@map("abono_falta")
}

/// Solicitação de férias.
model Ferias {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation("FeriasUser", fields: [userId], references: [id], onDelete: Cascade)
  inicio        DateTime          @db.Date
  fim           DateTime          @db.Date
  observacao    String?
  status        StatusSolicitacao @default(pendente)
  validadoPorId String?
  validadoPor   User?             @relation("FeriasValidador", fields: [validadoPorId], references: [id])
  createdAt     DateTime          @default(now())

  @@index([userId])
  @@index([status])
  @@map("ferias")
}

/// Registro de clima emocional. Anônimo na exibição (admin vê só agregado).
model RegistroEmocao {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  humor      Int // 1 (péssimo) a 5 (ótimo)
  comentario String?
  dia        DateTime @db.Date
  createdAt  DateTime @default(now())

  @@unique([userId, dia])
  @@index([dia])
  @@map("registro_emocao")
}

/// Feedback livre à empresa (Mód 1/9) enviado pelo herocard. Pode ser ANÔNIMO
/// (userId nulo → a RH não vê o autor). A action grava com `audit: false` p/ não
/// criar trilha que vincule o autor ao conteúdo quando anônimo.
model FeedbackHumor {
  id        String   @id @default(cuid())
  conteudo  String
  anonimo   Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("feedback_humor")
}

model ProjetoMembro {
  id        String  @id @default(cuid())
  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  papel     String? // ex.: coordenador, projetista

  @@unique([projetoId, userId])
  @@index([userId])
  @@map("projeto_membro")
}

model Disciplina {
  id           String           @id @default(cuid())
  projetoId    String
  projeto      Projeto          @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  nome         String
  status       StatusDisciplina @default(aguardando)
  prazo        DateTime?
  /// Quando a disciplina foi entregue/aprovada (p/ SLA de entregas).
  entregueEm   DateTime?
  /// Valor a pagar ao(s) projetista(s) por esta entrega.
  valor        Decimal?         @db.Decimal(12, 2)
  ordem        Int              @default(0)
  /// P-13: configura quais pacotes são obrigatórios para validação desta disciplina.
  exigePacoteA Boolean          @default(true)
  exigePacoteB Boolean          @default(true)

  responsaveis        DisciplinaResponsavel[]
  revisoes            RevisaoDisciplina[]
  uploads             Upload[]
  pagamentos          PagamentoProjetista[]
  canais              Canal[]
  eapTarefas          EapTarefa[]
  pranchas            Prancha[]
  solicitacoesRevisao SolicitacaoRevisao[]
  calculosFerramenta  CalculoFerramenta[]
  tarefas             Tarefa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projetoId])
  @@index([status])
  @@map("disciplina")
}

enum StatusSolicRevisao {
  pendente
  aceita
  recusada
}

/// Pedido formal de revisão de uma disciplina (workflow), com anexo opcional (B2).
model SolicitacaoRevisao {
  id             String             @id @default(cuid())
  disciplinaId   String
  disciplina     Disciplina         @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  solicitanteId  String
  motivo         String
  status         StatusSolicRevisao @default(pendente)
  respostaMotivo String?
  anexoPath      String?
  anexoNome      String?
  createdAt      DateTime           @default(now())
  respondidoEm   DateTime?

  @@index([disciplinaId])
  @@map("solicitacao_revisao")
}

/// Composição de preço detalhada do projeto (memória de cálculo) (B3).
model ProjetoComposicaoPreco {
  id         String                @id @default(cuid())
  projetoId  String                @unique
  projeto    Projeto               @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  observacao String?
  updatedAt  DateTime              @updatedAt
  itens      ItemComposicaoPreco[]

  @@map("projeto_composicao_preco")
}

model ItemComposicaoPreco {
  id            String                 @id @default(cuid())
  composicaoId  String
  composicao    ProjetoComposicaoPreco @relation(fields: [composicaoId], references: [id], onDelete: Cascade)
  descricao     String
  quantidade    Decimal                @default(1) @db.Decimal(12, 2)
  valorUnitario Decimal                @default(0) @db.Decimal(14, 2)
  ordem         Int                    @default(0)

  @@index([composicaoId])
  @@map("item_composicao_preco")
}

/// Configuração de Lista de Materiais (BIM) do projeto — texto livre (B4).
model LmConfig {
  id        String   @id @default(cuid())
  projetoId String   @unique
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  conteudo  String   @default("")
  updatedAt DateTime @updatedAt

  @@map("lm_config")
}

/// Linha de base do cronograma: snapshot nomeado das datas da EAP (B5).
model LinhaBase {
  id        String   @id @default(cuid())
  projetoId String
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  nome      String
  /// Snapshot [{ id, nome, inicio, fim }] das tarefas da EAP no momento.
  snapshot  Json
  createdAt DateTime @default(now())

  @@index([projetoId])
  @@map("linha_base")
}

enum StatusOportunidade {
  aberta
  ganha
  perdida
}

/// Oportunidade comercial (estágio entre Lead e Proposta) com atividades próprias (C1).
model Oportunidade {
  id            String                  @id @default(cuid())
  titulo        String
  /// FK escalar (resolvido por lookup) p/ não inflar Cliente.
  clienteId     String?
  valorEstimado Decimal?                @db.Decimal(14, 2)
  etapa         String                  @default("qualificacao")
  status        StatusOportunidade      @default(aberta)
  responsavelId String?
  observacao    String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  atividades    AtividadeOportunidade[]

  @@index([status])
  @@map("oportunidade")
}

model AtividadeOportunidade {
  id             String       @id @default(cuid())
  oportunidadeId String
  oportunidade   Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  tipo           String       @default("nota")
  descricao      String
  autorId        String
  createdAt      DateTime     @default(now())

  @@index([oportunidadeId])
  @@map("atividade_oportunidade")
}

// PropostaAnexo (C2) foi absorvido por `Documento` (docs do cliente, §Documentos do cliente).
// Os anexos existentes são migrados na migration `documentos_cliente`.

model DisciplinaResponsavel {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  @@unique([disciplinaId, userId])
  @@index([userId])
  @@map("disciplina_responsavel")
}

/// Log imutável de revisões (RV00, RV01…) por disciplina.
model RevisaoDisciplina {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  numero       Int // 0 = RV00
  motivo       String?
  autorId      String
  autor        User       @relation(fields: [autorId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([disciplinaId, numero])
  @@index([disciplinaId])
  @@map("revisao_disciplina")
}

// ─────────────────────────────────────────────────────────────
// Uploads & Validação → Pagamento (Onda 1)
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
// Tarefas (Onda 5a)
// ─────────────────────────────────────────────────────────────

model TarefaStatus {
  id        String  @id @default(cuid())
  nome      String  @unique
  ordem     Int     @default(0)
  cor       String?
  /// Coluna final: tarefas aqui contam como concluídas (libera dependentes).
  concluido Boolean @default(false)
  ativo     Boolean @default(true)

  tarefas Tarefa[]

  @@map("tarefa_status")
}

model Tarefa {
  id           String       @id @default(cuid())
  titulo       String
  descricao    String?
  statusId     String
  status       TarefaStatus @relation(fields: [statusId], references: [id])
  prazo        DateTime?    @db.Date
  /// Prioridade (baixa|media|alta|urgente). String livre p/ não exigir enum (igual a TicketSuporte).
  prioridade   String?
  projetoId    String?
  projeto      Projeto?     @relation(fields: [projetoId], references: [id])
  /// Disciplina do projeto à qual a tarefa pertence (aparece dentro dela na ficha do projeto).
  disciplinaId String?
  disciplina   Disciplina?  @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)
  criadorId    String
  criador      User         @relation("TarefaCriador", fields: [criadorId], references: [id])
  arquivada    Boolean      @default(false)
  /// Item 7: data em que a tarefa entrou num status final (concluída). Métrica de produtividade.
  concluidaEm  DateTime?
  /// Origem na EAP (P-32): evita gerar a mesma Tarefa operacional duas vezes.
  eapTarefaId  String?      @unique

  responsaveis TarefaResponsavel[]
  itens        TarefaItem[]
  dependeDe    TarefaDependencia[] @relation("Dependente")
  dependentes  TarefaDependencia[] @relation("DependeDe")
  comentarios  TarefaComentario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statusId, arquivada])
  @@index([projetoId])
  @@index([disciplinaId])
  @@map("tarefa")
}

model TarefaResponsavel {
  id       String @id @default(cuid())
  tarefaId String
  tarefa   Tarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([tarefaId, userId])
  @@map("tarefa_responsavel")
}

model TarefaItem {
  id        String  @id @default(cuid())
  tarefaId  String
  tarefa    Tarefa  @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  descricao String
  concluido Boolean @default(false)
  ordem     Int     @default(0)

  @@index([tarefaId])
  @@map("tarefa_item")
}

model TarefaDependencia {
  id          String @id @default(cuid())
  tarefaId    String
  tarefa      Tarefa @relation("Dependente", fields: [tarefaId], references: [id], onDelete: Cascade)
  dependeDeId String
  dependeDe   Tarefa @relation("DependeDe", fields: [dependeDeId], references: [id], onDelete: Cascade)

  @@unique([tarefaId, dependeDeId])
  @@map("tarefa_dependencia")
}

// ─────────────────────────────────────────────────────────────
// Jurídico (Onda 5b)
// ─────────────────────────────────────────────────────────────

model DocumentoJuridico {
  id         String         @id @default(cuid())
  titulo     String
  /// contrato | aditivo | proposta | procuracao | outro
  tipo       String         @default("contrato")
  projetoId  String?
  projeto    Projeto?       @relation(fields: [projetoId], references: [id])
  clienteId  String?
  cliente    Cliente?       @relation(fields: [clienteId], references: [id])
  pastaId    String?
  pasta      PastaJuridica? @relation(fields: [pastaId], references: [id], onDelete: SetNull)
  observacao String?
  createdAt  DateTime       @default(now())

  versoes DocJuridicoVersao[]

  @@index([projetoId])
  @@index([pastaId])
  @@map("documento_juridico")
}

/// Pasta (árvore) para organizar documentos jurídicos.
model PastaJuridica {
  id         String              @id @default(cuid())
  nome       String
  parentId   String?
  parent     PastaJuridica?      @relation("PastaArvore", fields: [parentId], references: [id], onDelete: SetNull)
  filhas     PastaJuridica[]     @relation("PastaArvore")
  documentos DocumentoJuridico[]
  ordem      Int                 @default(0)
  createdAt  DateTime            @default(now())

  @@index([parentId])
  @@map("pasta_juridica")
}

/// Documento (com versões) de um projeto — repositório geral, separado dos pacotes A/B de Upload.
// Repositório "Geral" do projeto (antigo ArquivoProjeto/ArquivoProjetoVersao) foi
// absorvido pelo model Documento (origem=interno) na Fase 5a — ver migração
// 20260705_documentos_geral e o plano 2026-07-05-documentos-fase5a-geral.md.

// ─────────────────────────────────────────────────────────────
// Documentos do cliente (Cliente → Proposta → Projeto)
// Material recebido de externos + docs que seguem o cliente. Ancora na Proposta
// (comercial) e/ou no Projeto; o Cliente é o dono. O Projeto gerado no aceite
// herda os docs da sua Proposta por consulta (join Proposta.projetoId) — sem cópia,
// sem mistura entre projetos irmãos. Absorve o antigo PropostaAnexo.
// Spec: docs/superpowers/plans/2026-07-05-recebidos-documentos-cliente.md
// ─────────────────────────────────────────────────────────────

enum OrigemDocumento {
  recebido_cliente // externo enviou (proposta/portal/link)
  interno // equipe subiu p/ compartilhar
  contrato
  comercial
}

enum CanalDocumento {
  interno
  portal
  link
}

model Documento {
  id         String            @id @default(cuid())
  clienteId  String // dono (denormalizado p/ ficha do cliente + escopo do portal)
  cliente    Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  propostaId String? // âncora comercial
  proposta   Proposta?         @relation(fields: [propostaId], references: [id], onDelete: SetNull)
  projetoId  String? // âncora de projeto (docs criados já na fase de projeto)
  projeto    Projeto?          @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  origem     OrigemDocumento   @default(recebido_cliente)
  canal      CanalDocumento    @default(interno)
  nome       String
  categoria  String?
  descricao  String?
  autorId    String? // null quando veio de link público sem user interno
  autor      User?             @relation("DocumentoAutor", fields: [autorId], references: [id])
  enviadoPor String? // nome digitado no link/portal (proveniência externa)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  versoes    DocumentoVersao[]

  @@index([clienteId])
  @@index([propostaId])
  @@index([projetoId])
  @@map("documento")
}

model DocumentoVersao {
  id          String    @id @default(cuid())
  documentoId String
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  numero      Int
  caminho     String
  nomeArquivo String
  mime        String
  tamanho     Int
  hashSha256  String
  autorId     String?
  createdAt   DateTime  @default(now())

  @@unique([documentoId, numero])
  @@index([documentoId])
  @@map("documento_versao")
}

/// Documento de RH de um colaborador (contrato, RG, ASO, diploma…).
model FuncionarioDocumento {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("FuncDocumentos", fields: [userId], references: [id], onDelete: Cascade)
  /// contrato | rg | cpf | aso | diploma | comprovante | outro
  tipo        String   @default("outro")
  nome        String
  caminho     String
  nomeArquivo String
  mime        String
  tamanho     Int
  hashSha256  String
  autorId     String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("funcionario_documento")
}

model DocJuridicoVersao {
  id          String            @id @default(cuid())
  documentoId String
  documento   DocumentoJuridico @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  numero      Int
  arquivoPath String
  arquivoNome String
  autorId     String
  autor       User              @relation(fields: [autorId], references: [id])
  createdAt   DateTime          @default(now())

  aceites AceiteDocumento[]

  @@unique([documentoId, numero])
  @@map("doc_juridico_versao")
}

/// Registro de aceite/assinatura interna (on-prem) de uma versão de documento jurídico:
/// snapshot de quem assinou, quando, e o hash SHA-256 do arquivo no momento do aceite.
model AceiteDocumento {
  id          String            @id @default(cuid())
  versaoId    String
  versao      DocJuridicoVersao @relation(fields: [versaoId], references: [id], onDelete: Cascade)
  userId      String
  userNome    String
  hashArquivo String
  assinadoEm  DateTime          @default(now())

  @@index([versaoId])
  @@map("aceite_documento")
}

model CertidaoTipo {
  id   String @id @default(cuid())
  nome String @unique

  certidoes Certidao[]

  @@map("certidao_tipo")
}

model Certidao {
  id               String                     @id @default(cuid())
  tipoId           String
  tipo             CertidaoTipo               @relation(fields: [tipoId], references: [id])
  descricao        String?
  validade         DateTime                   @db.Date
  arquivoPath      String?
  arquivoNome      String?
  createdAt        DateTime                   @default(now())
  versoes          CertidaoVersao[]
  habilitacaoItens LicitacaoHabilitacaoItem[]

  @@index([validade])
  @@map("certidao")
}

/// Versão histórica de uma certidão (E3).
model CertidaoVersao {
  id          String   @id @default(cuid())
  certidaoId  String
  certidao    Certidao @relation(fields: [certidaoId], references: [id], onDelete: Cascade)
  numero      Int
  validade    DateTime @db.Date
  arquivoPath String?
  arquivoNome String?
  autorId     String
  createdAt   DateTime @default(now())

  @@unique([certidaoId, numero])
  @@map("certidao_versao")
}

// ─────────────────────────────────────────────────────────────
// Licitações (Onda 5c)
// ─────────────────────────────────────────────────────────────

enum StatusLicitacao {
  em_andamento
  ganha
  perdida
  em_execucao
  concluida
}

enum TipoEventoLicitacao {
  abertura
  sessao
  resultado
  assinatura
  vigencia_inicio
  vigencia_fim
  // P1-B — recursos/impugnações reusam a mesma tabela
  pedido_esclarecimento
  impugnacao
  recurso
  contrarrazao
}

model Licitacao {
  id                   String          @id @default(cuid())
  titulo               String
  orgao                String?
  modalidade           String?
  numeroEdital         String?
  prazoProposta        DateTime?       @db.Date
  valorEstimado        Decimal?        @db.Decimal(14, 2)
  /// % máximo de subcontratação permitido pelo edital (por certame).
  subcontratacaoMaxPct Decimal?        @db.Decimal(5, 2)
  status               StatusLicitacao @default(em_andamento)
  observacoes          String?
  /// Projeto criado ao importar (status vira em_execucao).
  projetoId            String?         @unique
  projeto              Projeto?        @relation(fields: [projetoId], references: [id])

  /// PNCP — número de controle do edital/contrato.
  numeroControlePNCP String?
  pncpUrl            String?
  origemPNCP         Boolean   @default(false)
  publicadoPNCPEm    DateTime?

  docs                 DocumentoLicitacao[]
  medicoes             MedicaoLicitacao[]
  historico            LicitacaoHistorico[]
  valoresDisciplina    DisciplinaValorLicitacao[]
  eventos              LicitacaoEvento[]
  composicao           LicitacaoComposicaoPreco?
  contrato             ContratoLicitacao?
  habilitacao          LicitacaoHabilitacaoItem[]
  responsaveisTecnicos LicitacaoResponsavelTecnico[]
  subcontratacoes      SubcontratacaoLicitacao[]
  resultado            ResultadoLicitacao?
  viabilidade          ViabilidadeLicitacao?
  pncpLogs             IntegracaoPNCPLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("licitacao")
}

/// Evento na timeline de uma licitação (E4).
model LicitacaoHistorico {
  id          String    @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  descricao   String
  autorId     String?
  createdAt   DateTime  @default(now())

  @@index([licitacaoId])
  @@map("licitacao_historico")
}

/// Evento datado de uma licitação: datas-chave por fase (Item 1-B) e peças de recurso/impugnação (P1-B).
model LicitacaoEvento {
  id          String              @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao           @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  tipo        TipoEventoLicitacao
  data        DateTime            @db.Date
  /// Antecedências (em dias) para alerta; vazio = usa o padrão da config.
  alertaDias  Int[]               @default([])
  /// Para peças de recurso (P1): "propria" | "concorrente"; null para datas-chave.
  autoria     String?
  protocolo   String?
  observacao  String?
  /// Quando o evento já ocorreu/foi cumprido (some dos alertas).
  concluidoEm DateTime?
  createdAt   DateTime            @default(now())

  @@index([licitacaoId])
  @@index([data])
  @@map("licitacao_evento")
}

/// Valor por disciplina dentro de uma licitação/edital (E5).
model DisciplinaValorLicitacao {
  id          String    @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  disciplina  String
  valor       Decimal   @db.Decimal(14, 2)

  @@index([licitacaoId])
  @@map("disciplina_valor_licitacao")
}

/// Composição de preço da proposta da licitação (Item 2-A). Espelha ProjetoComposicaoPreco; copiada ao projeto no import.
model LicitacaoComposicaoPreco {
  id          String                    @id @default(cuid())
  licitacaoId String                    @unique
  licitacao   Licitacao                 @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  observacao  String?
  updatedAt   DateTime                  @updatedAt
  itens       ItemComposicaoLicitacao[]

  @@map("licitacao_composicao_preco")
}

model ItemComposicaoLicitacao {
  id            String                   @id @default(cuid())
  composicaoId  String
  composicao    LicitacaoComposicaoPreco @relation(fields: [composicaoId], references: [id], onDelete: Cascade)
  descricao     String
  quantidade    Decimal                  @default(1) @db.Decimal(12, 2)
  valorUnitario Decimal                  @default(0) @db.Decimal(14, 2)
  ordem         Int                      @default(0)

  @@index([composicaoId])
  @@map("item_composicao_licitacao")
}

model DocumentoLicitacao {
  id          String    @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  titulo      String

  versoes DocLicitacaoVersao[]

  @@index([licitacaoId])
  @@map("documento_licitacao")
}

model DocLicitacaoVersao {
  id          String             @id @default(cuid())
  documentoId String
  documento   DocumentoLicitacao @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  numero      Int
  arquivoPath String
  arquivoNome String
  autorId     String
  autor       User               @relation(fields: [autorId], references: [id])
  createdAt   DateTime           @default(now())

  @@unique([documentoId, numero])
  @@map("doc_licitacao_versao")
}

/// Medição → vira Lançamento de receita (1.02) previsto.
model MedicaoLicitacao {
  id           String    @id @default(cuid())
  licitacaoId  String
  licitacao    Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  numero       Int
  descricao    String?
  valor        Decimal   @db.Decimal(14, 2)
  data         DateTime  @db.Date
  lancamentoId String?   @unique

  @@unique([licitacaoId, numero])
  @@map("medicao_licitacao")
}

/// Modalidade de licitação — lista configurável (config-driven, editável em Configurações).
model Modalidade {
  id        String   @id @default(cuid())
  nome      String   @unique
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("modalidade")
}

/// Log de integração com o PNCP (import de editais / publicação de contrato).
model IntegracaoPNCPLog {
  id          String     @id @default(cuid())
  /// "import" | "publicacao"
  direcao     String
  referencia  String?
  licitacaoId String?
  licitacao   Licitacao? @relation(fields: [licitacaoId], references: [id], onDelete: SetNull)
  /// "ok" | "erro"
  status      String
  mensagem    String?
  payload     Json?
  createdAt   DateTime   @default(now())

  @@index([licitacaoId])
  @@map("integracao_pncp_log")
}

/// Modelo reutilizável de checklist de habilitação (global, editável em Configurações).
model ChecklistHabilitacaoModelo {
  id        String                           @id @default(cuid())
  nome      String                           @unique
  ativo     Boolean                          @default(true)
  ordem     Int                              @default(0)
  itens     ChecklistHabilitacaoModeloItem[]
  createdAt DateTime                         @default(now())

  @@map("checklist_habilitacao_modelo")
}

model ChecklistHabilitacaoModeloItem {
  id          String                     @id @default(cuid())
  modeloId    String
  modelo      ChecklistHabilitacaoModelo @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  exigencia   String
  obrigatorio Boolean                    @default(true)
  ordem       Int                        @default(0)

  @@index([modeloId])
  @@map("checklist_habilitacao_modelo_item")
}

/// Item do checklist de habilitação de uma licitação (instância). Pode apontar p/ uma Certidao da empresa.
model LicitacaoHabilitacaoItem {
  id          String    @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  exigencia   String
  certidaoId  String?
  certidao    Certidao? @relation(fields: [certidaoId], references: [id])
  atendido    Boolean   @default(false)
  obrigatorio Boolean   @default(true)
  observacao  String?
  ordem       Int       @default(0)

  @@index([licitacaoId])
  @@index([certidaoId])
  @@map("licitacao_habilitacao_item")
}

/// Responsável técnico (CREA/CAU) — global; pode ser colaborador interno (userId).
model ResponsavelTecnico {
  id         String                        @id @default(cuid())
  nome       String
  registro   String
  /// "CREA" | "CAU" | outro
  conselho   String?
  userId     String?                       @unique
  user       User?                         @relation(fields: [userId], references: [id])
  ativo      Boolean                       @default(true)
  createdAt  DateTime                      @default(now())
  licitacoes LicitacaoResponsavelTecnico[]

  @@map("responsavel_tecnico")
}

/// Vínculo RT ↔ licitação com o documento comprobatório (ART/RRT/CAT).
model LicitacaoResponsavelTecnico {
  id              String             @id @default(cuid())
  licitacaoId     String
  licitacao       Licitacao          @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  responsavelId   String
  responsavel     ResponsavelTecnico @relation(fields: [responsavelId], references: [id], onDelete: Cascade)
  /// "ART" | "RRT" | "CAT"
  documentoTipo   String
  numeroDocumento String?
  arquivoPath     String?
  arquivoNome     String?
  createdAt       DateTime           @default(now())

  @@unique([licitacaoId, responsavelId, documentoTipo])
  @@index([responsavelId])
  @@map("licitacao_responsavel_tecnico")
}

/// Subcontratado de uma licitação (P6). Percentual validado contra subcontratacaoMaxPct do edital.
model SubcontratacaoLicitacao {
  id           String      @id @default(cuid())
  licitacaoId  String
  licitacao    Licitacao   @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  nomeLivre    String?
  objeto       String
  percentual   Decimal     @db.Decimal(5, 2)

  @@index([licitacaoId])
  @@map("subcontratacao_licitacao")
}

/// Contrato/empenho pós-ganha (Item 3-B). valorHomologado pode diferir do estimado; aditivos ajustam.
model ContratoLicitacao {
  id                  String             @id @default(cuid())
  licitacaoId         String             @unique
  licitacao           Licitacao          @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  numeroContrato      String?
  numeroEmpenho       String?
  valorHomologado     Decimal            @db.Decimal(14, 2)
  /// Valor homologado INICIAL (pré-reajustes). Denominador do % de acréscimo de aditivo (Lei 14.133 art.125). Null = usar valorHomologado.
  valorHomologadoBase Decimal?           @db.Decimal(14, 2)
  vigenciaInicio      DateTime?          @db.Date
  vigenciaFim         DateTime?          @db.Date
  /// Regra/índice de reajuste em texto (estruturado vem na Fase 4).
  reajuste            String?
  garantiaTipo        String?
  garantiaValor       Decimal?           @db.Decimal(14, 2)
  garantiaValidade    DateTime?          @db.Date
  /// % limite de acréscimo (P2). Null = usa padrão da config licitacoes.config.
  limiteAcrescimoPct  Decimal?           @db.Decimal(5, 2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  aditivos            AditivoContrato[]
  riscos              MatrizRiscoItem[]
  reajustes           ReajusteContrato[]

  @@map("contrato_licitacao")
}

/// Termo aditivo de contrato (valor/prazo/objeto). valorDelta +/- ajusta o valor vigente.
model AditivoContrato {
  id            String            @id @default(cuid())
  contratoId    String
  contrato      ContratoLicitacao @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  /// "valor" | "prazo" | "valor_prazo" | "objeto"
  tipo          String
  valorDelta    Decimal?          @db.Decimal(14, 2)
  novaVigencia  DateTime?         @db.Date
  justificativa String?
  data          DateTime          @db.Date
  createdAt     DateTime          @default(now())

  @@index([contratoId])
  @@map("aditivo_contrato")
}

/// Item da matriz de risco do contrato (P4-B). Obras/serviços de engenharia (Lei 14.133).
model MatrizRiscoItem {
  id            String            @id @default(cuid())
  contratoId    String
  contrato      ContratoLicitacao @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  evento        String
  /// "baixa" | "media" | "alta"
  probabilidade String
  /// "baixo" | "medio" | "alto"
  impacto       String
  /// "contratante" | "contratado"
  alocacao      String
  mitigacao     String?
  ordem         Int               @default(0)

  @@index([contratoId])
  @@map("matriz_risco_item")
}

/// Reajuste/repactuação do contrato por índice (P8). aplicadoEm null = pendente/sugerido.
model ReajusteContrato {
  id              String            @id @default(cuid())
  contratoId      String
  contrato        ContratoLicitacao @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  indice          String
  percentual      Decimal           @db.Decimal(6, 3)
  dataBase        DateTime?         @db.Date
  aniversario     DateTime          @db.Date
  valorAnterior   Decimal           @db.Decimal(14, 2)
  valorReajustado Decimal           @db.Decimal(14, 2)
  /// null = pendente (sugerido pelo modo automático); preenchido = aplicado.
  aplicadoEm      DateTime?
  createdAt       DateTime          @default(now())

  @@index([contratoId])
  @@index([aniversario])
  @@map("reajuste_contrato")
}

enum TipoSancao {
  advertencia
  multa
  suspensao
  impedimento
  inidoneidade
}

/// Sanção contra a própria empresa (compliance).
model SancaoPropria {
  id         String     @id @default(cuid())
  tipo       TipoSancao
  valor      Decimal?   @db.Decimal(14, 2)
  inicio     DateTime?  @db.Date
  fim        DateTime?  @db.Date
  orgao      String?
  processo   String?
  observacao String?
  createdAt  DateTime   @default(now())

  @@index([fim])
  @@map("sancao_propria")
}

/// Sanção contra concorrente (inteligência comercial).
model SancaoConcorrente {
  id           String      @id @default(cuid())
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  nomeLivre    String?
  tipo         TipoSancao
  valor        Decimal?    @db.Decimal(14, 2)
  inicio       DateTime?   @db.Date
  fim          DateTime?   @db.Date
  orgao        String?
  processo     String?
  observacao   String?
  createdAt    DateTime    @default(now())

  @@index([fim])
  @@map("sancao_concorrente")
}

/// Resultado/concorrência de uma licitação (quem ganhou, valor, nossa classificação).
model ResultadoLicitacao {
  id                 String    @id @default(cuid())
  licitacaoId        String    @unique
  licitacao          Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  vencedor           String?
  valorVencedor      Decimal?  @db.Decimal(14, 2)
  nossaClassificacao Int?
  observacao         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("resultado_licitacao")
}

/// Viabilidade (go/no-go) de uma licitação. modo "fixo" usa os campos fixos; "configuravel" usa `criterios`.
model ViabilidadeLicitacao {
  id                   String                @id @default(cuid())
  licitacaoId          String                @unique
  licitacao            Licitacao             @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  /// "fixo" | "configuravel"
  modo                 String                @default("fixo")
  margemEsperadaPct    Decimal?              @db.Decimal(5, 2)
  equipeDisponivel     Boolean?
  concorrenciaPrevista String?
  /// "pendente" | "go" | "no_go"
  decisao              String                @default("pendente")
  decididoPorId        String?
  decididoPor          User?                 @relation("ViabilidadeDecisor", fields: [decididoPorId], references: [id])
  decididoEm           DateTime?
  justificativa        String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  criterios            ViabilidadeCriterio[]

  @@map("viabilidade_licitacao")
}

/// Critério livre de viabilidade (modo configurável).
model ViabilidadeCriterio {
  id            String               @id @default(cuid())
  viabilidadeId String
  viabilidade   ViabilidadeLicitacao @relation(fields: [viabilidadeId], references: [id], onDelete: Cascade)
  criterio      String
  atendido      Boolean              @default(false)
  observacao    String?
  ordem         Int                  @default(0)

  @@index([viabilidadeId])
  @@map("viabilidade_criterio")
}

// ─────────────────────────────────────────────────────────────
// Agenda (Onda 5d)
// ─────────────────────────────────────────────────────────────

model Compromisso {
  id        String    @id @default(cuid())
  titulo    String
  descricao String?
  local     String?
  inicio    DateTime
  fim       DateTime?
  criadorId String
  criador   User      @relation("CompromissoCriador", fields: [criadorId], references: [id])
  createdAt DateTime  @default(now())

  participantes CompromissoParticipante[]

  @@index([inicio])
  @@map("compromisso")
}

model CompromissoParticipante {
  id            String      @id @default(cuid())
  compromissoId String
  compromisso   Compromisso @relation(fields: [compromissoId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  /// null = pendente, true = confirmado, false = recusou
  confirmado    Boolean?

  @@unique([compromissoId, userId])
  @@map("compromisso_participante")
}

// ─────────────────────────────────────────────────────────────
// Qualidade (Onda 5e)
// ─────────────────────────────────────────────────────────────

/// Foto mensal do índice de retrabalho (revisões por disciplina).
model QualidadeSnapshot {
  id               String  @id @default(cuid())
  ano              Int
  mes              Int
  /// % de disciplinas com ao menos 1 revisão (RV>0).
  indice           Decimal @db.Decimal(5, 2)
  totalDisciplinas Int
  comRevisao       Int

  createdAt DateTime @default(now())

  @@unique([ano, mes])
  @@map("qualidade_snapshot")
}

/// Foto diária dos KPIs do dashboard (série histórica). Idempotente por dia.
model DashboardSnapshot {
  id                String   @id @default(cuid())
  dia               DateTime @unique @db.Date
  projetosAtivos    Int
  receitaPrevista   Decimal  @db.Decimal(14, 2)
  entregasPendentes Int
  recebidoNoMes     Decimal  @db.Decimal(14, 2)
  createdAt         DateTime @default(now())

  @@map("dashboard_snapshot")
}

// ─────────────────────────────────────────────────────────────
// Suporte (Onda 5f)
// ─────────────────────────────────────────────────────────────

enum StatusTicket {
  aberto
  em_atendimento
  resolvido
}

model TicketSuporte {
  id         String       @id @default(cuid())
  titulo     String
  descricao  String
  status     StatusTicket @default(aberto)
  /// Prioridade do ticket (ex.: baixa | media | alta | urgente). Livre p/ não exigir enum.
  prioridade String?
  /// Categoria do ticket (ex.: bug | duvida | melhoria | acesso).
  categoria  String?
  autorId    String
  autor      User         @relation("TicketAutor", fields: [autorId], references: [id])
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  mensagens TicketMensagem[]

  @@index([status])
  @@map("ticket_suporte")
}

model TicketMensagem {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    TicketSuporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User          @relation("TicketMensagemAutor", fields: [autorId], references: [id])
  texto     String        @default("")
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_mensagem")
}

// ─────────────────────────────────────────────────────────────
// Planejamento & Recursos (Onda 5)
// ─────────────────────────────────────────────────────────────

/// Tarefa da EAP (WBS) de um projeto — hierárquica, com datas previstas
/// (plano atual) e de linha de base (snapshot p/ o gantt de linha dupla).
model EapTarefa {
  id             String      @id @default(cuid())
  projetoId      String
  projeto        Projeto     @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         EapTarefa?  @relation("EapFilhas", fields: [parentId], references: [id], onDelete: Cascade)
  filhas         EapTarefa[] @relation("EapFilhas")
  disciplinaId   String?
  disciplina     Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)
  nome           String
  ordem          Int         @default(0)
  inicioPrevisto DateTime    @db.Date
  fimPrevisto    DateTime    @db.Date
  inicioBaseline DateTime?   @db.Date
  fimBaseline    DateTime?   @db.Date
  progresso      Int         @default(0)
  marco          Boolean     @default(false)

  predecessoras EapDependencia[] @relation("EapDependente")
  sucessoras    EapDependencia[] @relation("EapPredecessora")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projetoId])
  @@index([parentId])
  @@map("eap_tarefa")
}

/// Dependência FS entre tarefas da EAP (predecessora termina antes da sucessora iniciar).
model EapDependencia {
  id             String    @id @default(cuid())
  tarefaId       String
  tarefa         EapTarefa @relation("EapDependente", fields: [tarefaId], references: [id], onDelete: Cascade)
  predecessoraId String
  predecessora   EapTarefa @relation("EapPredecessora", fields: [predecessoraId], references: [id], onDelete: Cascade)

  @@unique([tarefaId, predecessoraId])
  @@index([predecessoraId])
  @@map("eap_dependencia")
}

/// Pessoa como recurso de planejamento (multiplicador de capacidade, custo/hora, cor).
model Recurso {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capacidade Decimal  @default(1.0) @db.Decimal(4, 2)
  custoHora  Decimal? @db.Decimal(10, 2)
  cor        String   @default("#576980")
  ativo      Boolean  @default(true)

  alocacoes Alocacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurso")
}

/// Alocação de um recurso a um projeto (percentual + período opcional). Base da matriz de recursos.
model Alocacao {
  id         String    @id @default(cuid())
  recursoId  String
  recurso    Recurso   @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  projetoId  String
  projeto    Projeto   @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  percentual Int       @default(100)
  inicio     DateTime? @db.Date
  fim        DateTime? @db.Date
  observacao String?

  createdAt DateTime @default(now())

  @@unique([recursoId, projetoId])
  @@index([projetoId])
  @@map("alocacao")
}

// ─────────────────────────────────────────────────────────────
// Comercial / CRM (Onda 4)
// ─────────────────────────────────────────────────────────────

/// Etapa do funil de vendas (Kanban configurável).
model FunilEtapa {
  id    String  @id @default(cuid())
  nome  String  @unique
  ordem Int     @default(0)
  cor   String?
  ativo Boolean @default(true)

  leads Lead[]

  @@map("funil_etapa")
}

model Lead {
  id            String     @id @default(cuid())
  nome          String
  contato       String?
  email         String?
  telefone      String?
  origem        String?
  valorEstimado Decimal?   @db.Decimal(14, 2)
  etapaId       String
  etapa         FunilEtapa @relation(fields: [etapaId], references: [id])
  /// Preenchido quando o lead é convertido em cliente.
  clienteId     String?
  cliente       Cliente?   @relation(fields: [clienteId], references: [id])
  observacoes   String?
  /// Motivo registrado ao mover o lead para a etapa "Perdido".
  motivoPerda   String?
  arquivado     Boolean    @default(false)

  atividades AtividadeLead[]
  propostas  Proposta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([etapaId, arquivado])
  @@map("lead")
}

model AtividadeLead {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  nota      String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("atividade_lead")
}

model MetaComercial {
  id    String  @id @default(cuid())
  ano   Int
  mes   Int
  valor Decimal @db.Decimal(14, 2)

  @@unique([ano, mes])
  @@map("meta_comercial")
}

/// Tabela de preço por m² por disciplina (preços automáticos da proposta).
model TabelaPreco {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)

  itens ItemTabelaPreco[]

  @@map("tabela_preco")
}

model ItemTabelaPreco {
  id         String      @id @default(cuid())
  tabelaId   String
  tabela     TabelaPreco @relation(fields: [tabelaId], references: [id], onDelete: Cascade)
  disciplina String
  valorM2    Decimal     @db.Decimal(12, 2)

  @@unique([tabelaId, disciplina])
  @@map("item_tabela_preco")
}

enum StatusProposta {
  rascunho
  enviada
  aceita
  recusada
}

model PropostaSequencia {
  ano    Int @id
  ultimo Int @default(0)

  @@map("proposta_sequencia")
}

model Proposta {
  id          String         @id @default(cuid())
  ano         Int
  sequencial  Int
  /// Número de exibição: PR-260001
  numero      String         @unique
  titulo      String
  clienteId   String
  cliente     Cliente        @relation(fields: [clienteId], references: [id])
  leadId      String?
  lead        Lead?          @relation(fields: [leadId], references: [id])
  status      StatusProposta @default(rascunho)
  areaM2      Decimal?       @db.Decimal(12, 2)
  validade    DateTime?      @db.Date
  observacoes String?
  /// Token do link público (/a/proposta/[token]).
  token       String         @unique
  autorId     String
  autor       User           @relation("PropostaAutor", fields: [autorId], references: [id])
  /// Projeto gerado no aceite.
  projetoId   String?        @unique
  projeto     Projeto?       @relation(fields: [projetoId], references: [id])

  enviadaEm DateTime?
  aceitaEm  DateTime?

  itens         PropostaItem[]
  condicoes     PropostaCondicao[]
  versoes       PropostaVersao[]
  visualizacoes PropostaVisualizacao[]
  documentos    Documento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ano, sequencial])
  @@index([status])
  @@index([clienteId])
  @@map("proposta")
}

model PropostaItem {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  disciplina String
  descricao  String?
  valor      Decimal  @db.Decimal(14, 2)
  ordem      Int      @default(0)

  @@index([propostaId])
  @@map("proposta_item")
}

enum TipoCondicao {
  percentual
  valor
}

model PropostaCondicao {
  id         String       @id @default(cuid())
  propostaId String
  proposta   Proposta     @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  descricao  String
  tipo       TipoCondicao @default(percentual)
  valor      Decimal      @db.Decimal(14, 2)
  ordem      Int          @default(0)

  @@index([propostaId])
  @@map("proposta_condicao")
}

/// Snapshot da proposta a cada salvar (itens+condições serializados).
model PropostaVersao {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  numero     Int
  snapshot   Json
  autorId    String
  autor      User     @relation("PropostaVersaoAutor", fields: [autorId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([propostaId, numero])
  @@map("proposta_versao")
}

/// Abertura registrada pelo pixel do link público.
model PropostaVisualizacao {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([propostaId])
  @@map("proposta_visualizacao")
}

// ─────────────────────────────────────────────────────────────
// Estúdio de Documentos (Onda D) — modelos de relatório em bandas
// ─────────────────────────────────────────────────────────────

enum TipoDocumento {
  relatorio
  proposta
  contrato
  recibo
  holerite
  outro
}

/// Modelo (template) de documento. Layout em bandas no schemaJson.
model DocumentoModelo {
  id           String        @id @default(cuid())
  nome         String
  descricao    String?
  tipo         TipoDocumento @default(relatorio)
  /// Fonte de dados padrão (id do registry em modules/documentos/fontes.ts).
  fonte        String?
  schemaJson   Json
  ativo        Boolean       @default(true)
  /// Dono do modelo (autor). Null = modelo de sistema/legado.
  donoId       String?
  /// Visibilidade do modelo: "pessoal" (só o dono) | "perfis" (perfis em `perfis`) | "global" (todos).
  visibilidade String        @default("global")
  /// Perfis que enxergam o modelo quando visibilidade = "perfis".
  perfis       Role[]        @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  versoes DocumentoModeloVersao[]

  @@index([tipo, ativo])
  @@map("documento_modelo")
}

/// Histórico de versões (criada a cada salvar).
model DocumentoModeloVersao {
  id         String          @id @default(cuid())
  modeloId   String
  modelo     DocumentoModelo @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  numero     Int
  schemaJson Json
  autorId    String
  autor      User            @relation(fields: [autorId], references: [id])
  createdAt  DateTime        @default(now())

  @@unique([modeloId, numero])
  @@map("documento_modelo_versao")
}

/// Documento gerado e persistido (histórico imutável do que foi produzido/enviado).
/// Snapshot do schema + dados resolvidos no momento da geração; nomes guardados p/ sobreviver à exclusão.
model DocumentoGerado {
  id             String   @id @default(cuid())
  modeloId       String?
  modeloNome     String
  fonte          String?
  params         Json
  schemaSnapshot Json
  dadosSnapshot  Json
  geradoPorId    String
  geradoPorNome  String
  /// Numeração automática (sequência por série). Ex.: série "REL", número 142.
  serie          String?
  numero         Int?
  /// Caminho do PDF salvo em storage (opcional; setado quando PDF é gerado e salvo automaticamente).
  arquivoPath    String?
  createdAt      DateTime @default(now())

  @@index([modeloId])
  @@index([createdAt])
  @@map("documento_gerado")
}

/// Dataset reutilizável importado de CSV — vira uma coleção (linhas) p/ o Estúdio (D3).
model DatasetDocumento {
  id        String   @id @default(cuid())
  nome      String
  colunas   Json
  linhas    Json
  donoId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dataset_documento")
}

/// Bloco reutilizável de elementos do Estúdio (cabeçalho, assinatura, carimbo) — biblioteca (D5).
model BlocoDocumento {
  id            String   @id @default(cuid())
  nome          String
  conteudo      Json
  donoId        String?
  compartilhado Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("bloco_documento")
}

// ─────────────────────────────────────────────────────────────
// RH — Folha CLT, Onboarding, NF de PJ (Onda 3e/3f/3g)
// ─────────────────────────────────────────────────────────────

enum TipoRubrica {
  provento
  desconto
}

/// Catálogo de rubricas da folha (salário, VT, INSS, IRRF…).
model RubricaFolha {
  id    String      @id @default(cuid())
  nome  String      @unique
  tipo  TipoRubrica
  ordem Int         @default(0)
  ativo Boolean     @default(true)

  itens HoleriteItem[]

  @@map("rubrica_folha")
}

/// Faixa de encargo da folha (INSS/IRRF). Sem valores embutidos — configurável em Configurações.
model EncargoFaixa {
  id       String  @id @default(cuid())
  tipo     String // "inss" | "irrf"
  limite   Decimal @db.Decimal(14, 2) // limite superior da faixa
  aliquota Decimal @db.Decimal(6, 3) // %
  deduzir  Decimal @default(0) @db.Decimal(14, 2) // parcela a deduzir (IRRF)
  ordem    Int     @default(0)

  @@index([tipo, ordem])
  @@map("encargo_faixa")
}

/// Dependente de um colaborador (p/ dedução de IRRF e cadastro de RH).
model Dependente {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome       String
  nascimento DateTime? @db.Date
  parentesco String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("dependente")
}

/// Prancha (folha técnica) de uma disciplina — código, título, revisão, escala.
/// Lista Mestre de Documentos: uma folha técnica por disciplina.
/// Código composto (não persistido): {projeto}-{sigla disciplina}-{fase}-{numeracao4}-{tipo}[-Rnn].
model Prancha {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  folha        String
  tipo         String
  fase         String
  numeracao    Int
  revisao      Int        @default(0)
  conteudo     String?    @db.Text
  ordem        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([disciplinaId])
  @@map("prancha")
}

enum CategoriaPranchaCatalogo {
  folha
  tipo
  fase
}

/// Configuração de nomenclatura da Lista Mestre. Linha global = projetoId null (singleton);
/// linha por projeto sobrescreve. `exigir` liga/desliga o alerta de nome fora do padrão;
/// `padrao` é um regex custom (opcional) — vazio usa o padrão embutido.
model NomenclaturaConfig {
  id        String   @id @default(cuid())
  projetoId String?  @unique
  projeto   Projeto? @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  exigir    Boolean  @default(true)
  padrao    String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("nomenclatura_config")
}

/// Catálogo de siglas da Lista Mestre (folha/tipo/fase). Global (projetoId null)
/// ou específico de um projeto. A sigla é usada na composição do código da prancha.
model PranchaCatalogo {
  id        String                   @id @default(cuid())
  categoria CategoriaPranchaCatalogo
  sigla     String
  nome      String
  ativo     Boolean                  @default(true)
  ordem     Int                      @default(0)
  projetoId String?
  projeto   Projeto?                 @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  createdAt DateTime                 @default(now())

  @@index([categoria, projetoId])
  @@map("prancha_catalogo")
}

/// Feriado (cadastro p/ ponto/escala/banco de horas). Data única.
model Feriado {
  id        String   @id @default(cuid())
  data      DateTime @unique @db.Date
  nome      String
  tipo      String   @default("nacional") // nacional | estadual | municipal
  createdAt DateTime @default(now())

  @@map("feriado")
}

/// Comentário de tarefa (texto e/ou anexo).
model TarefaComentario {
  id        String   @id @default(cuid())
  tarefaId  String
  tarefa    Tarefa   @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation("TarefaComentarioAutor", fields: [autorId], references: [id])
  texto     String   @default("")
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime @default(now())

  @@index([tarefaId])
  @@map("tarefa_comentario")
}

/// Habilidade/competência (catálogo).
model Habilidade {
  id       String           @id @default(cuid())
  nome     String           @unique
  usuarios UserHabilidade[]

  @@map("habilidade")
}

/// Vínculo colaborador × habilidade.
model UserHabilidade {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  habilidadeId String
  habilidade   Habilidade @relation(fields: [habilidadeId], references: [id], onDelete: Cascade)

  @@unique([userId, habilidadeId])
  @@map("user_habilidade")
}

/// Serviço terceirizado contratado para um projeto (fornecedor externo).
model ServicoTerceirizado {
  id           String      @id @default(cuid())
  projetoId    String
  projeto      Projeto     @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  descricao    String
  valor        Decimal?    @db.Decimal(14, 2)
  status       String      @default("contratado") // contratado | concluido | cancelado
  /// Vínculo com o Financeiro: despesa prevista (contratado) / confirmada (concluido).
  lancamentoId String?     @unique
  createdAt    DateTime    @default(now())

  @@index([projetoId])
  @@map("servico_terceirizado")
}

enum StatusFolha {
  aberta
  fechada
}

model FolhaPagamento {
  id           String      @id @default(cuid())
  ano          Int
  mes          Int // 1-12
  status       StatusFolha @default(aberta)
  fechadaEm    DateTime?
  /// Lançamento de despesa (2.03) criado ao fechar.
  lancamentoId String?     @unique

  holerites Holerite[]
  createdAt DateTime   @default(now())

  @@unique([ano, mes])
  @@map("folha_pagamento")
}

model Holerite {
  id        String         @id @default(cuid())
  folhaId   String
  folha     FolhaPagamento @relation(fields: [folhaId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  enviadoEm DateTime?

  itens HoleriteItem[]

  @@unique([folhaId, userId])
  @@map("holerite")
}

model HoleriteItem {
  id         String        @id @default(cuid())
  holeriteId String
  holerite   Holerite      @relation(fields: [holeriteId], references: [id], onDelete: Cascade)
  rubricaId  String?
  rubrica    RubricaFolha? @relation(fields: [rubricaId], references: [id])
  descricao  String
  tipo       TipoRubrica
  valor      Decimal       @db.Decimal(12, 2)

  @@index([holeriteId])
  @@map("holerite_item")
}

model OnboardingTemplate {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)

  itens     OnboardingTemplateItem[]
  processos OnboardingProcesso[]

  @@map("onboarding_template")
}

model OnboardingTemplateItem {
  id         String             @id @default(cuid())
  templateId String
  template   OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  descricao  String
  ordem      Int                @default(0)

  @@index([templateId])
  @@map("onboarding_template_item")
}

/// Checklist de admissão de um colaborador (1 por usuário).
model OnboardingProcesso {
  id         String              @id @default(cuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?
  template   OnboardingTemplate? @relation(fields: [templateId], references: [id])
  createdAt  DateTime            @default(now())

  itens OnboardingItem[]

  @@map("onboarding_processo")
}

model OnboardingItem {
  id          String             @id @default(cuid())
  processoId  String
  processo    OnboardingProcesso @relation(fields: [processoId], references: [id], onDelete: Cascade)
  descricao   String
  ordem       Int                @default(0)
  concluido   Boolean            @default(false)
  concluidoEm DateTime?

  @@index([processoId])
  @@map("onboarding_item")
}

enum StatusNF {
  enviada
  aprovada
  rejeitada
}

/// Nota fiscal enviada por PJ/freelancer para faturar pagamentos.
model NotaFiscalPJ {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("NfUser", fields: [userId], references: [id])
  numero      String?
  valor       Decimal  @db.Decimal(12, 2)
  /// Caminho relativo a STORAGE_BASE_PATH.
  arquivoPath String
  arquivoNome String
  status      StatusNF @default(enviada)
  observacao  String?

  validadoPorId String?
  validadoPor   User?     @relation("NfValidador", fields: [validadoPorId], references: [id])
  validadoEm    DateTime?

  createdAt DateTime                @default(now())
  historico NotaFiscalPJHistorico[]

  @@index([userId, status])
  @@map("nota_fiscal_pj")
}

/// Trilha de status da NF de PJ (D6).
model NotaFiscalPJHistorico {
  id        String       @id @default(cuid())
  notaId    String
  nota      NotaFiscalPJ @relation(fields: [notaId], references: [id], onDelete: Cascade)
  de        String?
  para      String
  autorId   String?
  createdAt DateTime     @default(now())

  @@index([notaId])
  @@map("nota_fiscal_pj_historico")
}

/// Feedback / 1:1 de RH sobre um colaborador (D5).
model FeedbackRH {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("FeedbackAlvo", fields: [userId], references: [id], onDelete: Cascade)
  autorId   String
  /// feedback | reuniao_1a1 | reconhecimento | alerta
  tipo      String   @default("feedback")
  conteudo  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("feedback_rh")
}

enum OrigemUpload {
  manual
  ferramenta
}

enum PacoteUpload {
  A // plantas / memoriais
  B // backup do software
  OUTROS // formatos não suportados
  RECEBIDOS // Item 17 (beta): arquivos recebidos do cliente
}

model Upload {
  id           String       @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina   @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  pacote       PacoteUpload
  nomeArquivo  String
  /// Caminho relativo a STORAGE_BASE_PATH (nunca absoluto).
  caminho      String
  hashSha256   String
  tamanho      Int
  mimeType     String?
  versao       Int          @default(1)
  origem       OrigemUpload @default(manual)

  validado      Boolean   @default(false)
  validadoPorId String?
  validadoPor   User?     @relation("UploadValidador", fields: [validadoPorId], references: [id])
  validadoEm    DateTime?

  /// Ajuste solicitado pelo validador (validação parcial): motivo + quem/quando.
  revisaoObs   String?
  revisaoEm    DateTime?
  revisaoPorId String?
  revisaoPor   User?     @relation("UploadRevisor", fields: [revisaoPorId], references: [id])

  autorId   String
  autor     User     @relation("UploadAutor", fields: [autorId], references: [id])
  createdAt DateTime @default(now())

  aceite     AceiteCliente?
  pendencias Pendencia[]    @relation("UploadPendencias")

  @@index([disciplinaId, pacote])
  @@index([autorId])
  @@map("upload")
}

/// Apontamento posicional (pendência) sobre uma prancha PDF, na tela de visualização.
/// Amarra à VERSÃO do arquivo (uploadId) — congela na revisão em que foi feito.
/// Numeração sequencial por prancha/rodada (escopo uploadId). Vira item de checklist
/// de UMA tarefa por prancha. Refs de disciplina/projeto/usuário são denormalizadas
/// (resolvidas por query), sem FK, para manter a migração enxuta.
model Pendencia {
  id             String    @id @default(cuid())
  uploadId       String
  upload         Upload    @relation("UploadPendencias", fields: [uploadId], references: [id], onDelete: Cascade)
  disciplinaId   String
  projetoId      String
  numero         Int
  pagina         Int
  /// Âncora normalizada (0..1) relativa à página — sobrevive a zoom/DPI.
  x              Float
  y              Float
  texto          String
  /// aberta | resolvida | fechada | descartada
  status         String    @default("aberta")
  autorId        String
  tarefaId       String?
  tarefaItemId   String?
  resolvidoPorId String?
  resolvidoEm    DateTime?
  fechadoPorId   String?
  fechadoEm      DateTime?
  createdAt      DateTime  @default(now())

  @@index([uploadId, numero])
  @@index([disciplinaId])
  @@index([projetoId, status])
  @@map("pendencia")
}

/// N-43: Aceite digital do cliente para uma entrega validada.
model AceiteCliente {
  id           String    @id @default(cuid())
  uploadId     String    @unique
  upload       Upload    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  token        String    @unique
  /// pendente | aceito | revisao
  situacao     String    @default("pendente")
  respondidoEm DateTime?
  observacao   String?
  geradoPorId  String
  geradoPor    User      @relation("AceiteGerador", fields: [geradoPorId], references: [id])
  createdAt    DateTime  @default(now())

  @@map("aceite_cliente")
}

enum StatusPagamento {
  pendente
  pago
  cancelado
}

/// Pagamento ao projetista por entrega validada. Na Onda 2 será
/// vinculado a um Lançamento financeiro (campo lancamentoId).
model PagamentoProjetista {
  id               String           @id @default(cuid())
  disciplinaId     String
  disciplina       Disciplina       @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  projetistaId     String
  projetista       User             @relation("PagamentoProjetista", fields: [projetistaId], references: [id])
  valor            Decimal          @db.Decimal(12, 2)
  tipoProfissional String // role do projetista no momento da liberação
  status           StatusPagamento  @default(pendente)
  liberadoEm       DateTime         @default(now())
  pagoEm           DateTime?
  observacao       String?
  lancamentoId     String? // vínculo futuro com o Financeiro (Onda 2)
  /// Lote de folha de projetistas (A8).
  folhaId          String?
  folha            FolhaProjetista? @relation(fields: [folhaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([projetistaId, status])
  @@index([disciplinaId])
  @@index([folhaId])
  @@map("pagamento_projetista")
}

enum StatusFolhaProjetista {
  aberta
  fechada
  paga
}

/// Lote mensal de pagamentos de projetistas (A8): agrupa PagamentoProjetista do período.
model FolhaProjetista {
  id        String                @id @default(cuid())
  ano       Int
  mes       Int
  status    StatusFolhaProjetista @default(aberta)
  total     Decimal               @default(0) @db.Decimal(14, 2)
  fechadaEm DateTime?
  pagaEm    DateTime?
  createdAt DateTime              @default(now())

  pagamentos PagamentoProjetista[]

  @@unique([ano, mes])
  @@map("folha_projetista")
}

/// Anexo (comprovante) de um lançamento financeiro (A6).
model LancamentoAnexo {
  id           String     @id @default(cuid())
  lancamentoId String
  lancamento   Lancamento @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  caminho      String
  nome         String
  mime         String
  tamanho      Int
  autorId      String
  createdAt    DateTime   @default(now())

  @@index([lancamentoId])
  @@map("lancamento_anexo")
}

/// Trilha de mudanças de status de um lançamento (A6).
model LancamentoStatusHistorico {
  id           String     @id @default(cuid())
  lancamentoId String
  lancamento   Lancamento @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  de           String?
  para         String
  autorId      String?
  createdAt    DateTime   @default(now())

  @@index([lancamentoId])
  @@map("lancamento_status_historico")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Planejamento de Pagamentos (mesa de planejamento)
// ─────────────────────────────────────────────────────────────

enum StatusPlanejamento {
  rascunho
  analise
  aprovado
  executado
  cancelado
}

/// Cenário de planejamento de pagamentos: simula o uso do caixa disponível sobre
/// as contas em aberto, com ordem de prioridade e saldo acumulado recalculado no cliente.
model PlanejamentoPagamento {
  id              String             @id @default(cuid())
  nome            String
  status          StatusPlanejamento @default(rascunho)
  /// Saldo disponível informado para o planejamento.
  saldoDisponivel Decimal            @db.Decimal(14, 2)
  /// Janela de vencimentos considerada ao montar o plano (opcional).
  periodoIni      DateTime?          @db.Date
  periodoFim      DateTime?          @db.Date
  /// Filtros opcionais aplicados ao carregar as contas.
  contaId         String?
  conta           ContaBancaria?     @relation(fields: [contaId], references: [id])
  centroId        String?
  centro          CentroCusto?       @relation(fields: [centroId], references: [id])
  projetoId       String?
  projeto         Projeto?           @relation(fields: [projetoId], references: [id])
  observacoes     String?
  responsavelId   String
  responsavel     User               @relation(fields: [responsavelId], references: [id])
  /// Aprovação/execução (scalars sem relação, como no padrão do Lancamento).
  aprovadoPorId   String?
  aprovadoEm      DateTime?
  executadoEm     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  linhas PlanejamentoLinha[]

  @@index([status])
  @@map("planejamento_pagamento")
}

/// Linha do plano: um lançamento previsto (a pagar/receber) com ordem de prioridade
/// e valor planejado (parcial permitido). O saldo acumulado é calculado, não persistido.
model PlanejamentoLinha {
  id             String                @id @default(cuid())
  planoId        String
  plano          PlanejamentoPagamento @relation(fields: [planoId], references: [id], onDelete: Cascade)
  lancamentoId   String
  lancamento     Lancamento            @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  ordem          Int                   @default(0)
  valorPlanejado Decimal               @db.Decimal(14, 2)
  selecionada    Boolean               @default(true)

  @@unique([planoId, lancamentoId])
  @@index([planoId])
  @@map("planejamento_linha")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Fechamento Mensal
// ─────────────────────────────────────────────────────────────

enum StatusFechamento {
  aberto
  fechado
}

/// Consolidação financeira do mês: receita/despesa confirmadas + folha de projetistas
/// com retenções/descontos automáticos (alíquotas configuráveis). Snapshot ao gerar.
model FechamentoMensal {
  id                String           @id @default(cuid())
  ano               Int
  mes               Int
  status            StatusFechamento @default(aberto)
  receitaConfirmada Decimal          @default(0) @db.Decimal(14, 2)
  despesaConfirmada Decimal          @default(0) @db.Decimal(14, 2)
  folhaBruta        Decimal          @default(0) @db.Decimal(14, 2)
  retencaoIss       Decimal          @default(0) @db.Decimal(14, 2)
  retencaoInss      Decimal          @default(0) @db.Decimal(14, 2)
  retencaoIr        Decimal          @default(0) @db.Decimal(14, 2)
  descontos         Decimal          @default(0) @db.Decimal(14, 2)
  /// Snapshot das alíquotas (%) aplicadas no momento da geração.
  aliquotas         Json?
  observacoes       String?
  responsavelId     String
  responsavel       User             @relation(fields: [responsavelId], references: [id])
  fechadoEm         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([ano, mes])
  @@index([status])
  @@map("fechamento_mensal")
}

/// Snapshot mensal de métricas de licitação (série histórica do funil).
model LicitacaoMetricaMensal {
  id             String   @id @default(cuid())
  ano            Int
  mes            Int
  totalAbertas   Int      @default(0)
  totalGanhas    Int      @default(0)
  totalPerdidas  Int      @default(0)
  valorGanho     Decimal  @default(0) @db.Decimal(14, 2)
  valorPerdido   Decimal  @default(0) @db.Decimal(14, 2)
  valorEmDisputa Decimal  @default(0) @db.Decimal(14, 2)
  createdAt      DateTime @default(now())

  @@unique([ano, mes])
  @@map("licitacao_metrica_mensal")
}

// ─────────────────────────────────────────────────────────────
// Ferramentas de Engenharia (F0)
// ─────────────────────────────────────────────────────────────

/// Snapshot persistido de um cálculo de ferramenta de engenharia.
/// entradasJson e resultadoJson são o input/output do engine no momento do salvamento.
model CalculoFerramenta {
  id            String  @id @default(cuid())
  /// Chave estável da ferramenta (ex.: "U01", "E01") — igual ao registry.ts.
  ferramenta    String
  titulo        String
  /// Norma de referência aplicada (ex.: "NBR 6118:2023"). Nulo para ferramentas sem norma.
  norma         String?
  /// Versão do engine de cálculo (incrementada quando a lógica muda e salva incompatibilidades).
  versaoCalc    Int     @default(1)
  entradasJson  Json
  resultadoJson Json

  autorId      String
  autor        User        @relation(fields: [autorId], references: [id])
  projetoId    String?
  projeto      Projeto?    @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  disciplinaId String?
  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([autorId, ferramenta, createdAt])
  @@index([projetoId])
  @@map("calculo_ferramenta")
}

// ─────────────────────────────────────────────────────────────
// Patrimônio / Ativos (Mód 16 do CONSELHO1)
// ─────────────────────────────────────────────────────────────

/// Item do inventário do escritório (equipamentos, mobiliário, veículos…).
model Ativo {
  id            String     @id @default(cuid())
  nome          String
  categoria     String? // ex.: Computador, Mobiliário, Veículo, Periférico…
  localizacao   String?
  responsavelId String?
  responsavel   User?      @relation("AtivoResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  dataAquisicao DateTime?  @db.Date
  valor         Decimal?   @db.Decimal(12, 2)
  /// ativo | manutencao | baixado
  status        String     @default("ativo")
  observacao    String?
  /// Se este ativo é uma máquina de TI gerenciada (1:1 opcional).
  maquina       MaquinaTI?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([categoria])
  @@index([status])
  @@map("ativo")
}

/// PC/estação gerenciada pela TI — specs + peças + histórico de manutenção.
model MaquinaTI {
  id            String              @id @default(cuid())
  nome          String
  /// Vínculo opcional ao item de inventário correspondente.
  patrimonioId  String?             @unique
  patrimonio    Ativo?              @relation(fields: [patrimonioId], references: [id], onDelete: SetNull)
  responsavelId String?
  responsavel   User?               @relation("MaquinaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  // Specs livres (texto)
  cpu           String?
  ram           String?
  armazenamento String?
  so            String? // sistema operacional
  observacao    String?
  componentes   ComponenteMaquina[]
  manutencoes   ManutencaoMaquina[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([responsavelId])
  @@map("maquina_ti")
}

/// Peça/componente instalado numa máquina.
model ComponenteMaquina {
  id         String    @id @default(cuid())
  maquinaId  String
  maquina    MaquinaTI @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
  tipo       String // ex.: Memória, SSD, GPU, Fonte, Placa-mãe
  descricao  String
  quantidade Int       @default(1)
  createdAt  DateTime  @default(now())

  @@index([maquinaId])
  @@map("componente_maquina")
}

/// Registro de manutenção/troca de uma máquina.
model ManutencaoMaquina {
  id        String    @id @default(cuid())
  maquinaId String
  maquina   MaquinaTI @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
  data      DateTime  @db.Date
  descricao String
  custo     Decimal?  @db.Decimal(12, 2)
  createdAt DateTime  @default(now())

  @@index([maquinaId])
  @@map("manutencao_maquina")
}
