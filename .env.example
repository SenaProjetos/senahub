# ─── Banco de dados ───────────────────────────────────────────
# Dev: porta 5433 (a 5432 é o Docker do sistema antigo). Prod: porta padrão 5432.
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5433/senahub_remake"

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
# URL base usada em links de notificações/e-mails. Em prod = domínio público https.
APP_URL="http://localhost:3000"

# ─── Auth (better-auth) ───────────────────────────────────────
# Segredo forte (32+ bytes). Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""
# Origem p/ CSRF/cookies. Em prod = domínio público https (ex.: https://hub.exemplo.com.br).
BETTER_AUTH_URL="http://localhost:3000"

# ─── Armazenamento de arquivos (caminho Windows, precisa existir) ─
STORAGE_BASE_PATH="C:\\caminho\\para\\storage"

# ─── PDF (puppeteer-core) — caminho do Chrome/Chromium ────────
CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

# ─── SMTP (e-mail) — opcional ─────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Web Push (VAPID) — opcional ──────────────────────────────
# Gerar: npx web-push generate-vapid-keys
# ATENÇÃO: a chave PÚBLICA precisa do prefixo NEXT_PUBLIC_ (lida no cliente, em BUILD-TIME).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@example.com"

# ─── Backup automático (pg_dump) — opcional (prod) ────────────
ENABLE_BACKUP="0"
BACKUP_PATH="C:\\caminho\\para\\backups"
PG_DUMP_PATH="C:\\Program Files\\PostgreSQL\\17\\bin\\pg_dump.exe"
