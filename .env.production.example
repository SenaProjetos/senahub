# ════════════════════════════════════════════════════════════════
# SenaHub — .env de PRODUÇÃO (servidor Windows + Cloudflare Tunnel)
# Copie para `.env` no servidor e preencha os valores REAIS.
# Substitua todos os <<...>>. NÃO comite este arquivo preenchido.
# ════════════════════════════════════════════════════════════════

# ─── Banco de dados (PostgreSQL nativo no servidor) ───────────
# Prod usa a porta padrão 5432. Crie um usuário dedicado (não use 'postgres' superuser).
DATABASE_URL="postgresql://senahub:<<SENHA_FORTE>>@localhost:5432/senahub"

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
# Domínio público do túnel (o cloudflared aponta para http://localhost:3000):
APP_URL="https://<<hub.seudominio.com.br>>"

# ─── Auth (better-auth) ───────────────────────────────────────
# GERE UM SEGREDO NOVO (não reutilize o de dev):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="<<SEGREDO_32_BYTES_NOVO>>"
# Tem que ser EXATAMENTE a origem pública https (CSRF/cookies seguros):
BETTER_AUTH_URL="https://<<hub.seudominio.com.br>>"

# ─── Armazenamento (pasta Windows existente, com backup) ──────
STORAGE_BASE_PATH="D:\\SenaHub\\storage"

# ─── PDF — Chrome já instalado no servidor ────────────────────
CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

# ─── Backup automático (recomendado em prod) ──────────────────
ENABLE_BACKUP="1"
BACKUP_PATH="D:\\SenaHub\\backups"
PG_DUMP_PATH="C:\\Program Files\\PostgreSQL\\17\\bin\\pg_dump.exe"

# ─── SMTP (e-mail) — opcional ─────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── Web Push (VAPID) — opcional ──────────────────────────────
# A PÚBLICA (NEXT_PUBLIC_) é lida em BUILD-TIME → defina ANTES de `npm run build`.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:ti@seudominio.com.br"
