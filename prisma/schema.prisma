generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Identidade & acesso
// ─────────────────────────────────────────────────────────────

enum Role {
  admin
  supervisor
  administrativo
  clt
  estagiario
  projetista_pj
  freelancer
  cliente
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?

  // Campos de domínio
  role               Role       @default(cliente)
  ativo              Boolean    @default(true)
  mustChangePassword Boolean    @default(false)
  chatStatus         ChatStatus @default(disponivel)
  /// Vínculo do usuário externo (role cliente) ao Cliente que ele representa no portal.
  clienteId          String?
  cliente            Cliente?   @relation("ClienteUsuarios", fields: [clienteId], references: [id])
  /// Salário base do colaborador CLT/estagiário (p/ geração automática de holerites).
  salarioBase        Decimal?   @db.Decimal(12, 2)
  /// Data de admissão (CLT) — base do período aquisitivo de férias.
  dataAdmissao       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  auditLogs AuditLog[]
  resetSolicitacoes SolicitacaoResetSenha[]

  projetosMembro       ProjetoMembro[]
  disciplinasResponsavel DisciplinaResponsavel[]
  revisoes             RevisaoDisciplina[]
  uploadsAutor         Upload[]              @relation("UploadAutor")
  uploadsValidados     Upload[]              @relation("UploadValidador")
  pagamentos           PagamentoProjetista[] @relation("PagamentoProjetista")
  socio                Socio?
  lancamentosAutor     Lancamento[]          @relation("LancamentoAutor")
  canaisMembro         CanalMembro[]
  mensagens            Mensagem[]
  sessoes              SessaoTrabalho[]
  escala               EscalaTrabalho?
  abonos               AbonoFalta[]          @relation("AbonoUser")
  abonosValidados      AbonoFalta[]          @relation("AbonoValidador")
  ferias               Ferias[]              @relation("FeriasUser")
  feriasValidadas      Ferias[]              @relation("FeriasValidador")
  emocoes              RegistroEmocao[]
  holerites            Holerite[]
  onboarding           OnboardingProcesso?
  notasFiscais         NotaFiscalPJ[]        @relation("NfUser")
  nfsValidadas         NotaFiscalPJ[]        @relation("NfValidador")
  documentoVersoes     DocumentoModeloVersao[]
  atividadesLead       AtividadeLead[]
  propostasAutor       Proposta[]            @relation("PropostaAutor")
  propostaVersoes      PropostaVersao[]      @relation("PropostaVersaoAutor")
  tarefasCriadas       Tarefa[]              @relation("TarefaCriador")
  tarefasResponsavel   TarefaResponsavel[]
  docJuridicoVersoes   DocJuridicoVersao[]
  docLicitacaoVersoes  DocLicitacaoVersao[]
  compromissosCriados  Compromisso[]         @relation("CompromissoCriador")
  compromissosConvites CompromissoParticipante[]
  ticketsAutor         TicketSuporte[]       @relation("TicketAutor")
  ticketMensagens      TicketMensagem[]      @relation("TicketMensagemAutor")
  recurso              Recurso?
  dependentes          Dependente[]
  tarefaComentarios    TarefaComentario[]    @relation("TarefaComentarioAutor")
  habilidades          UserHabilidade[]
  rateios              RateioHora[]
  funcDocumentos       FuncionarioDocumento[] @relation("FuncDocumentos")
  bancoHoras           BancoHorasMensal[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Pedido de reset de senha (admin reinicia pela tela de usuários).
model SolicitacaoResetSenha {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resolvida Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolvida])
  @@map("solicitacao_reset_senha")
}

// ─────────────────────────────────────────────────────────────
// Permissões finas (recurso:ação), configuráveis em runtime
// ─────────────────────────────────────────────────────────────

model Permissao {
  id      String  @id @default(cuid())
  role    Role
  recurso String
  acao    String
  permitido Boolean @default(true)

  @@unique([role, recurso, acao])
  @@index([role])
  @@map("permissao")
}

// ─────────────────────────────────────────────────────────────
// Auditoria (registro imutável de toda mutação)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  modulo     String
  acao       String
  tipo       String   @default("acao") // acao | login | erro
  resultado  String   @default("sucesso") // sucesso | falha | bloqueado
  entidade   String?
  entidadeId String?
  detalhe    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([modulo])
  @@index([createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// Notificações (sininho interno) + Web Push
// ─────────────────────────────────────────────────────────────

model Notificacao {
  id        String   @id @default(cuid())
  userId    String
  titulo    String
  corpo     String?
  href      String?
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lida])
  @@map("notificacao")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscription")
}

// ─────────────────────────────────────────────────────────────
// Configuração geral do sistema (chave/valor)
// ─────────────────────────────────────────────────────────────

model ConfigSistema {
  chave     String   @id
  valor     Json
  updatedAt DateTime @updatedAt

  @@map("config_sistema")
}

// ─────────────────────────────────────────────────────────────
// Clientes (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoPessoa {
  PF
  PJ
}

model Cliente {
  id           String     @id @default(cuid())
  tipo         TipoPessoa @default(PJ)
  nome         String // nome (PF) ou razão social (PJ)
  nomeFantasia String?
  documento    String? // CPF ou CNPJ
  email        String?
  telefone     String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?

  observacoes String?
  ativo       Boolean  @default(true)

  // Login externo opcional do cliente (criado sob demanda).
  usuarioId String? @unique

  contatos    ContatoCliente[]
  projetos    Projeto[]
  lancamentos Lancamento[]
  leads       Lead[]
  propostas   Proposta[]
  usuarios    User[]             @relation("ClienteUsuarios")
  docsJuridicos DocumentoJuridico[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([ativo])
  @@index([nome])
  @@map("cliente")
}

model ContatoCliente {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nome      String
  cargo     String?
  email     String?
  telefone  String?
  principal Boolean @default(false)

  @@index([clienteId])
  @@map("contato_cliente")
}

// ─────────────────────────────────────────────────────────────
// Projetos & Disciplinas (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoProjeto {
  particular
  licitacao
}

enum SituacaoProjeto {
  em_andamento
  concluido
  arquivado
  cancelado
}

enum StatusDisciplina {
  aguardando
  em_andamento
  em_revisao
  entregue
  aprovado
}

/// Catálogo configurável de disciplinas (Estrutural, Hidráulica…).
model DisciplinaCatalogo {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  @@map("disciplina_catalogo")
}

/// Sequência atômica do número AAXXXX por ano.
model ProjetoSequencia {
  ano    Int @id
  ultimo Int @default(0)

  @@map("projeto_sequencia")
}

model Projeto {
  id          String          @id @default(cuid())
  ano         Int
  sequencial  Int
  /// Código de exibição AAXXXX (ex.: 260142).
  codigo      String          @unique
  tipo        TipoProjeto     @default(particular)
  situacao    SituacaoProjeto @default(em_andamento)
  nome        String
  descricao   String?
  clienteId   String
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  areaM2      Decimal?        @db.Decimal(12, 2)
  endereco    String?
  prazoFinal  DateTime?

  disciplinas Disciplina[]
  membros     ProjetoMembro[]
  inputs      InputProjeto[]
  linkInput   LinkPublicoInput?
  lancamentos Lancamento[]
  canais      Canal[]
  proposta    Proposta?
  tarefas     Tarefa[]
  docsJuridicos DocumentoJuridico[]
  licitacao   Licitacao?
  sessoes     SessaoTrabalho[]
  eapTarefas  EapTarefa[]
  alocacoes   Alocacao[]
  servicos    ServicoTerceirizado[]
  rateios     RateioHora[]
  arquivos    ArquivoProjeto[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([ano, sequencial])
  @@index([clienteId])
  @@index([situacao])
  @@map("projeto")
}

/// Campo de input do projeto (pergunta + resposta do cliente).
model InputProjeto {
  id         String   @id @default(cuid())
  projetoId  String
  projeto    Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplina String? // null = geral; senão nome da disciplina
  pergunta   String
  resposta   String?
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projetoId])
  @@map("input_projeto")
}

/// Link público (por token) para o cliente preencher os inputs sem login.
model LinkPublicoInput {
  id        String   @id @default(cuid())
  projetoId String   @unique
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  token     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("link_publico_input")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Cadastros base (Onda 2a)
// ─────────────────────────────────────────────────────────────

enum TipoCategoria {
  receita
  despesa
}

/// Plano de contas hierárquico (código ex.: "2.01").
model CategoriaFinanceira {
  id     String        @id @default(cuid())
  codigo String        @unique
  nome   String
  tipo   TipoCategoria
  paiId  String?
  pai    CategoriaFinanceira?  @relation("CategoriaFilhas", fields: [paiId], references: [id])
  filhas CategoriaFinanceira[] @relation("CategoriaFilhas")
  ordem  Int           @default(0)
  ativo  Boolean       @default(true)
  /// Atividade no DFC: "operacional" | "investimento" | "financiamento" (default operacional).
  grupoDfc String?

  lancamentos Lancamento[]
  regras      RegraCategorizacao[]
  orcamentos  OrcamentoItem[]

  @@index([tipo, ativo])
  @@map("categoria_financeira")
}

/// Valor orçado (planejado) de uma categoria para um ano — base do orçamento editável.
model OrcamentoItem {
  id             String              @id @default(cuid())
  ano            Int
  categoriaId    String
  categoria      CategoriaFinanceira @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  valorPlanejado Decimal             @db.Decimal(14, 2)
  updatedAt      DateTime            @updatedAt

  @@unique([ano, categoriaId])
  @@index([ano])
  @@map("orcamento_item")
}

model CentroCusto {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos Lancamento[]

  @@map("centro_custo")
}

enum TipoContaBancaria {
  corrente
  poupanca
  caixa
  investimento
}

model ContaBancaria {
  id           String            @id @default(cuid())
  nome         String
  tipo         TipoContaBancaria @default(corrente)
  banco        String?
  agencia      String?
  numero       String?
  saldoInicial Decimal           @default(0) @db.Decimal(14, 2)
  padrao       Boolean           @default(false)
  ativo        Boolean           @default(true)
  ordem        Int               @default(0)

  lancamentos Lancamento[]
  extratos    ExtratoBancario[]
  transacoes  TransacaoBancaria[]

  @@map("conta_bancaria")
}

model FormaPagamento {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos Lancamento[]

  @@map("forma_pagamento")
}

model Fornecedor {
  id          String     @id @default(cuid())
  tipo        TipoPessoa @default(PJ)
  nome        String
  documento   String?
  email       String?
  telefone    String?
  /// Tipo de serviço (topografia, sondagem, ensaios…)
  servico     String?
  observacoes String?
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lancamentos Lancamento[]
  servicos    ServicoTerceirizado[]

  @@index([ativo])
  @@map("fornecedor")
}

model Socio {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  percentual Decimal  @db.Decimal(5, 2)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("socio")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Lançamentos (ledger) + contas a pagar/receber (Onda 2b)
// ─────────────────────────────────────────────────────────────

enum TipoLancamento {
  receita
  despesa
}

enum StatusLancamento {
  previsto // conta a pagar/receber em aberto
  aguardando_aprovacao // despesa acima da alçada, trava até aprovação
  confirmado // pago/recebido (entra no caixa e na DRE)
  cancelado
}

/// Lançamento financeiro. previsto = conta a pagar/receber; confirmado = realizado.
model Lancamento {
  id        String           @id @default(cuid())
  tipo      TipoLancamento
  descricao String
  valor     Decimal          @db.Decimal(14, 2)
  /// Valor efetivamente pago/recebido (parcial). Se null, considera `valor`.
  valorEfetivo Decimal?      @db.Decimal(14, 2)
  status    StatusLancamento @default(previsto)

  /// Competência/realização. `vencimento` para previstos; `dataConfirmacao` ao realizar.
  data            DateTime  @db.Date
  vencimento      DateTime? @db.Date
  dataConfirmacao DateTime? @db.Date

  categoriaId String
  categoria   CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  centroId    String?
  centro      CentroCusto?        @relation(fields: [centroId], references: [id])
  contaId     String?
  conta       ContaBancaria?      @relation(fields: [contaId], references: [id])
  formaId     String?
  forma       FormaPagamento?     @relation(fields: [formaId], references: [id])
  projetoId   String?
  projeto     Projeto?            @relation(fields: [projetoId], references: [id])
  fornecedorId String?
  fornecedor   Fornecedor?        @relation(fields: [fornecedorId], references: [id])
  clienteId   String?
  cliente     Cliente?            @relation(fields: [clienteId], references: [id])

  observacao       String?
  recorrenciaGrupo String?
  /// Documento-fonte (NF/contrato/proposta/medição) — rastreabilidade de origem (Fase 2).
  documentoFinanceiroId String?
  documentoFinanceiro   DocumentoFinanceiro? @relation(fields: [documentoFinanceiroId], references: [id], onDelete: SetNull)
  /// Aprovação por alçada (Fase 4): quem aprovou, quando, e motivo se rejeitado.
  aprovadoPorId  String?
  aprovadoEm     DateTime?
  motivoRejeicao String?
  /// Vínculo com a folha de projetistas (Onda 2c).
  pagamentoProjetistaId String? @unique

  autorId String
  autor   User   @relation("LancamentoAutor", fields: [autorId], references: [id])

  transacao TransacaoBancaria?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, status])
  @@index([vencimento])
  @@index([data])
  @@index([projetoId])
  @@index([documentoFinanceiroId])
  @@map("lancamento")
}

enum TipoDocumentoFinanceiro {
  nf_entrada
  nf_servico
  contrato
  proposta
  medicao
}

/// Documento-fonte de movimentações financeiras (rastreabilidade + parcelamento). Fase 2.
/// Híbrido: modelo próprio p/ NF/contrato; `referenciaId` reaproveita Proposta/Medição existentes.
model DocumentoFinanceiro {
  id             String                  @id @default(cuid())
  tipo           TipoDocumentoFinanceiro
  numero         String?
  dataEmissao    DateTime?               @db.Date
  valorDocumento Decimal?                @db.Decimal(14, 2)
  /// FKs escalares (sem relação, resolvidos por lookup) p/ não inflar Fornecedor/Cliente.
  fornecedorId   String?
  clienteId      String?
  /// Quando tipo = proposta|medicao: id da Proposta/MedicaoLicitacao reaproveitada (ref. soft).
  referenciaId   String?
  arquivoPath    String?
  arquivoNome    String?
  arquivoMime    String?
  observacao     String?
  autorId        String
  createdAt      DateTime                @default(now())

  lancamentos Lancamento[]

  @@index([tipo])
  @@map("documento_financeiro")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Conciliação bancária (OFX) (Onda 2d)
// ─────────────────────────────────────────────────────────────

model ExtratoBancario {
  id          String              @id @default(cuid())
  contaId     String
  conta       ContaBancaria       @relation(fields: [contaId], references: [id])
  nomeArquivo String?
  importadoEm DateTime            @default(now())
  transacoes  TransacaoBancaria[]

  @@index([contaId])
  @@map("extrato_bancario")
}

model TransacaoBancaria {
  id          String          @id @default(cuid())
  extratoId   String
  extrato     ExtratoBancario @relation(fields: [extratoId], references: [id], onDelete: Cascade)
  contaId     String
  conta       ContaBancaria   @relation(fields: [contaId], references: [id])
  /// Identificador único da transação no OFX (dedup).
  fitid       String
  data        DateTime        @db.Date
  /// Positivo = entrada, negativo = saída.
  valor       Decimal         @db.Decimal(14, 2)
  descricao   String
  conciliado  Boolean         @default(false)
  /// Lançamento ao qual esta transação foi conciliada.
  lancamentoId String?        @unique
  lancamento   Lancamento?    @relation(fields: [lancamentoId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contaId, fitid])
  @@index([contaId, conciliado])
  @@map("transacao_bancaria")
}

/// Regra de auto-categorização: descrição que casa → categoria sugerida.
model RegraCategorizacao {
  id          String              @id @default(cuid())
  termo       String
  categoriaId String
  categoria   CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  ativo       Boolean             @default(true)

  @@map("regra_categorizacao")
}

// ─────────────────────────────────────────────────────────────
// Chat interno (Onda 3a)
// ─────────────────────────────────────────────────────────────

enum TipoCanal {
  geral
  projeto
  disciplina
  dm
}

enum ChatStatus {
  disponivel
  ocupado
  reuniao
}

model Canal {
  id           String      @id @default(cuid())
  tipo         TipoCanal
  nome         String?
  projetoId    String?
  projeto      Projeto?    @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplinaId String?
  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  membros   CanalMembro[]
  mensagens Mensagem[]
  createdAt DateTime      @default(now())

  @@index([tipo])
  @@index([projetoId])
  @@index([disciplinaId])
  @@map("canal")
}

model CanalMembro {
  id         String    @id @default(cuid())
  canalId    String
  canal      Canal     @relation(fields: [canalId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?

  @@unique([canalId, userId])
  @@index([userId])
  @@map("canal_membro")
}

model Mensagem {
  id        String   @id @default(cuid())
  canalId   String
  canal     Canal    @relation(fields: [canalId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  conteudo  String
  fixada    Boolean  @default(false)
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime @default(now())
  editedAt  DateTime?

  @@index([canalId, createdAt])
  @@map("mensagem")
}

// ─────────────────────────────────────────────────────────────
// RH — Ponto, banco de horas, rateio (Onda 3b)
// ─────────────────────────────────────────────────────────────

/// Uma sessão de trabalho (cronômetro). fim=null = em andamento.
/// Troca de projeto fecha a sessão atual e abre outra → tempo por projeto.
model SessaoTrabalho {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projetoId String?
  projeto   Projeto?  @relation(fields: [projetoId], references: [id])
  inicio    DateTime
  fim       DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, inicio])
  @@index([projetoId])
  @@map("sessao_trabalho")
}

/// Jornada esperada do colaborador (para cálculo de saldo de banco de horas).
model EscalaTrabalho {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  horasDia Decimal @default(8) @db.Decimal(4, 2)
  ativo    Boolean @default(true)

  @@map("escala_trabalho")
}

/// Rateio mensal do custo de horas trabalhadas por projeto (Fluxo C: ponto → custo → margem).
/// Snapshot fechado por mês: congela o custo/hora vigente no momento do fechamento.
model RateioHora {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projetoId String
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  ano       Int
  mes       Int
  minutos   Int
  /// Custo/hora usado no fechamento (snapshot de Recurso.custoHora ou derivado do salário base).
  custoHora Decimal  @db.Decimal(10, 2)
  /// Custo total rateado = minutos / 60 × custoHora.
  custo     Decimal  @db.Decimal(12, 2)
  fechadoEm DateTime @default(now())

  @@unique([userId, projetoId, ano, mes])
  @@index([projetoId, ano, mes])
  @@map("rateio_hora")
}

/// Fechamento mensal do banco de horas: congela saldo do mês e o acumulado (carry-forward).
model BancoHorasMensal {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ano              Int
  mes              Int
  /// Saldo do mês (trabalhado − esperado), em minutos.
  saldoMinutos     Int
  /// Saldo acumulado até este mês (carry-forward), em minutos.
  acumuladoMinutos Int
  fechadoEm        DateTime @default(now())

  @@unique([userId, ano, mes])
  @@index([userId])
  @@map("banco_horas_mensal")
}

// ─────────────────────────────────────────────────────────────
// RH — Abono, férias, clima (Onda 3c)
// ─────────────────────────────────────────────────────────────

enum StatusSolicitacao {
  pendente
  aprovado
  rejeitado
}

/// Abono de faltas via atestado. Supervisor/RH valida.
model AbonoFalta {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation("AbonoUser", fields: [userId], references: [id], onDelete: Cascade)
  dataInicio   DateTime          @db.Date
  dataFim      DateTime          @db.Date
  motivo       String?
  atestadoPath String?
  atestadoNome String?
  status       StatusSolicitacao @default(pendente)
  validadoPorId String?
  validadoPor   User?            @relation("AbonoValidador", fields: [validadoPorId], references: [id])
  validadoEm   DateTime?
  createdAt    DateTime          @default(now())

  @@index([userId])
  @@index([status])
  @@map("abono_falta")
}

/// Solicitação de férias.
model Ferias {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation("FeriasUser", fields: [userId], references: [id], onDelete: Cascade)
  inicio        DateTime          @db.Date
  fim           DateTime          @db.Date
  observacao    String?
  status        StatusSolicitacao @default(pendente)
  validadoPorId String?
  validadoPor   User?             @relation("FeriasValidador", fields: [validadoPorId], references: [id])
  createdAt     DateTime          @default(now())

  @@index([userId])
  @@index([status])
  @@map("ferias")
}

/// Registro de clima emocional. Anônimo na exibição (admin vê só agregado).
model RegistroEmocao {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  humor      Int // 1 (péssimo) a 5 (ótimo)
  comentario String?
  dia        DateTime @db.Date
  createdAt  DateTime @default(now())

  @@unique([userId, dia])
  @@index([dia])
  @@map("registro_emocao")
}

model ProjetoMembro {
  id        String  @id @default(cuid())
  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  papel     String? // ex.: coordenador, projetista

  @@unique([projetoId, userId])
  @@index([userId])
  @@map("projeto_membro")
}

model Disciplina {
  id        String           @id @default(cuid())
  projetoId String
  projeto   Projeto          @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  nome      String
  status    StatusDisciplina @default(aguardando)
  prazo     DateTime?
  /// Quando a disciplina foi entregue/aprovada (p/ SLA de entregas).
  entregueEm DateTime?
  /// Valor a pagar ao(s) projetista(s) por esta entrega.
  valor     Decimal?         @db.Decimal(12, 2)
  ordem     Int              @default(0)

  responsaveis DisciplinaResponsavel[]
  revisoes     RevisaoDisciplina[]
  uploads      Upload[]
  pagamentos   PagamentoProjetista[]
  canais       Canal[]
  eapTarefas   EapTarefa[]
  pranchas     Prancha[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projetoId])
  @@index([status])
  @@map("disciplina")
}

model DisciplinaResponsavel {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  @@unique([disciplinaId, userId])
  @@index([userId])
  @@map("disciplina_responsavel")
}

/// Log imutável de revisões (RV00, RV01…) por disciplina.
model RevisaoDisciplina {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  numero       Int // 0 = RV00
  motivo       String?
  autorId      String
  autor        User       @relation(fields: [autorId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([disciplinaId, numero])
  @@index([disciplinaId])
  @@map("revisao_disciplina")
}

// ─────────────────────────────────────────────────────────────
// Uploads & Validação → Pagamento (Onda 1)
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
// Tarefas (Onda 5a)
// ─────────────────────────────────────────────────────────────

model TarefaStatus {
  id        String  @id @default(cuid())
  nome      String  @unique
  ordem     Int     @default(0)
  cor       String?
  /// Coluna final: tarefas aqui contam como concluídas (libera dependentes).
  concluido Boolean @default(false)
  ativo     Boolean @default(true)

  tarefas Tarefa[]

  @@map("tarefa_status")
}

model Tarefa {
  id        String       @id @default(cuid())
  titulo    String
  descricao String?
  statusId  String
  status    TarefaStatus @relation(fields: [statusId], references: [id])
  prazo     DateTime?    @db.Date
  projetoId String?
  projeto   Projeto?     @relation(fields: [projetoId], references: [id])
  criadorId String
  criador   User         @relation("TarefaCriador", fields: [criadorId], references: [id])
  arquivada Boolean      @default(false)

  responsaveis TarefaResponsavel[]
  itens        TarefaItem[]
  dependeDe    TarefaDependencia[] @relation("Dependente")
  dependentes  TarefaDependencia[] @relation("DependeDe")
  comentarios  TarefaComentario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statusId, arquivada])
  @@map("tarefa")
}

model TarefaResponsavel {
  id       String @id @default(cuid())
  tarefaId String
  tarefa   Tarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([tarefaId, userId])
  @@map("tarefa_responsavel")
}

model TarefaItem {
  id        String  @id @default(cuid())
  tarefaId  String
  tarefa    Tarefa  @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  descricao String
  concluido Boolean @default(false)
  ordem     Int     @default(0)

  @@index([tarefaId])
  @@map("tarefa_item")
}

model TarefaDependencia {
  id          String @id @default(cuid())
  tarefaId    String
  tarefa      Tarefa @relation("Dependente", fields: [tarefaId], references: [id], onDelete: Cascade)
  dependeDeId String
  dependeDe   Tarefa @relation("DependeDe", fields: [dependeDeId], references: [id], onDelete: Cascade)

  @@unique([tarefaId, dependeDeId])
  @@map("tarefa_dependencia")
}

// ─────────────────────────────────────────────────────────────
// Jurídico (Onda 5b)
// ─────────────────────────────────────────────────────────────

model DocumentoJuridico {
  id         String   @id @default(cuid())
  titulo     String
  /// contrato | aditivo | proposta | procuracao | outro
  tipo       String   @default("contrato")
  projetoId  String?
  projeto    Projeto? @relation(fields: [projetoId], references: [id])
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])
  pastaId    String?
  pasta      PastaJuridica? @relation(fields: [pastaId], references: [id], onDelete: SetNull)
  observacao String?
  createdAt  DateTime @default(now())

  versoes DocJuridicoVersao[]

  @@index([projetoId])
  @@index([pastaId])
  @@map("documento_juridico")
}

/// Pasta (árvore) para organizar documentos jurídicos.
model PastaJuridica {
  id         String              @id @default(cuid())
  nome       String
  parentId   String?
  parent     PastaJuridica?      @relation("PastaArvore", fields: [parentId], references: [id], onDelete: SetNull)
  filhas     PastaJuridica[]     @relation("PastaArvore")
  documentos DocumentoJuridico[]
  ordem      Int                 @default(0)
  createdAt  DateTime            @default(now())

  @@index([parentId])
  @@map("pasta_juridica")
}

/// Documento (com versões) de um projeto — repositório geral, separado dos pacotes A/B de Upload.
model ArquivoProjeto {
  id        String                 @id @default(cuid())
  projetoId String
  projeto   Projeto                @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  nome      String
  /// contrato | planta | memorial | foto | administrativo | outro
  categoria String?
  descricao String?
  autorId   String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  versoes   ArquivoProjetoVersao[]

  @@index([projetoId])
  @@map("arquivo_projeto")
}

model ArquivoProjetoVersao {
  id          String         @id @default(cuid())
  arquivoId   String
  arquivo     ArquivoProjeto @relation(fields: [arquivoId], references: [id], onDelete: Cascade)
  numero      Int
  caminho     String
  nomeArquivo String
  mime        String
  tamanho     Int
  hashSha256  String
  autorId     String
  createdAt   DateTime       @default(now())

  @@unique([arquivoId, numero])
  @@index([arquivoId])
  @@map("arquivo_projeto_versao")
}

/// Documento de RH de um colaborador (contrato, RG, ASO, diploma…).
model FuncionarioDocumento {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("FuncDocumentos", fields: [userId], references: [id], onDelete: Cascade)
  /// contrato | rg | cpf | aso | diploma | comprovante | outro
  tipo        String   @default("outro")
  nome        String
  caminho     String
  nomeArquivo String
  mime        String
  tamanho     Int
  hashSha256  String
  autorId     String
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("funcionario_documento")
}

model DocJuridicoVersao {
  id          String            @id @default(cuid())
  documentoId String
  documento   DocumentoJuridico @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  numero      Int
  arquivoPath String
  arquivoNome String
  autorId     String
  autor       User              @relation(fields: [autorId], references: [id])
  createdAt   DateTime          @default(now())

  @@unique([documentoId, numero])
  @@map("doc_juridico_versao")
}

model CertidaoTipo {
  id   String @id @default(cuid())
  nome String @unique

  certidoes Certidao[]

  @@map("certidao_tipo")
}

model Certidao {
  id          String       @id @default(cuid())
  tipoId      String
  tipo        CertidaoTipo @relation(fields: [tipoId], references: [id])
  descricao   String?
  validade    DateTime     @db.Date
  arquivoPath String?
  arquivoNome String?
  createdAt   DateTime     @default(now())

  @@index([validade])
  @@map("certidao")
}

// ─────────────────────────────────────────────────────────────
// Licitações (Onda 5c)
// ─────────────────────────────────────────────────────────────

enum StatusLicitacao {
  em_andamento
  ganha
  perdida
  em_execucao
  concluida
}

model Licitacao {
  id             String          @id @default(cuid())
  titulo         String
  orgao          String?
  modalidade     String?
  numeroEdital   String?
  prazoProposta  DateTime?       @db.Date
  valorEstimado  Decimal?        @db.Decimal(14, 2)
  status         StatusLicitacao @default(em_andamento)
  observacoes    String?
  /// Projeto criado ao importar (status vira em_execucao).
  projetoId      String?         @unique
  projeto        Projeto?        @relation(fields: [projetoId], references: [id])

  docs     DocumentoLicitacao[]
  medicoes MedicaoLicitacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("licitacao")
}

model DocumentoLicitacao {
  id          String    @id @default(cuid())
  licitacaoId String
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  titulo      String

  versoes DocLicitacaoVersao[]

  @@index([licitacaoId])
  @@map("documento_licitacao")
}

model DocLicitacaoVersao {
  id          String             @id @default(cuid())
  documentoId String
  documento   DocumentoLicitacao @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  numero      Int
  arquivoPath String
  arquivoNome String
  autorId     String
  autor       User               @relation(fields: [autorId], references: [id])
  createdAt   DateTime           @default(now())

  @@unique([documentoId, numero])
  @@map("doc_licitacao_versao")
}

/// Medição → vira Lançamento de receita (1.02) previsto.
model MedicaoLicitacao {
  id           String    @id @default(cuid())
  licitacaoId  String
  licitacao    Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  numero       Int
  descricao    String?
  valor        Decimal   @db.Decimal(14, 2)
  data         DateTime  @db.Date
  lancamentoId String?   @unique

  @@unique([licitacaoId, numero])
  @@map("medicao_licitacao")
}

// ─────────────────────────────────────────────────────────────
// Agenda (Onda 5d)
// ─────────────────────────────────────────────────────────────

model Compromisso {
  id        String    @id @default(cuid())
  titulo    String
  descricao String?
  local     String?
  inicio    DateTime
  fim       DateTime?
  criadorId String
  criador   User      @relation("CompromissoCriador", fields: [criadorId], references: [id])
  createdAt DateTime  @default(now())

  participantes CompromissoParticipante[]

  @@index([inicio])
  @@map("compromisso")
}

model CompromissoParticipante {
  id            String      @id @default(cuid())
  compromissoId String
  compromisso   Compromisso @relation(fields: [compromissoId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  /// null = pendente, true = confirmado, false = recusou
  confirmado    Boolean?

  @@unique([compromissoId, userId])
  @@map("compromisso_participante")
}

// ─────────────────────────────────────────────────────────────
// Qualidade (Onda 5e)
// ─────────────────────────────────────────────────────────────

/// Foto mensal do índice de retrabalho (revisões por disciplina).
model QualidadeSnapshot {
  id               String  @id @default(cuid())
  ano              Int
  mes              Int
  /// % de disciplinas com ao menos 1 revisão (RV>0).
  indice           Decimal @db.Decimal(5, 2)
  totalDisciplinas Int
  comRevisao       Int

  createdAt DateTime @default(now())

  @@unique([ano, mes])
  @@map("qualidade_snapshot")
}

/// Foto diária dos KPIs do dashboard (série histórica). Idempotente por dia.
model DashboardSnapshot {
  id                String   @id @default(cuid())
  dia               DateTime @unique @db.Date
  projetosAtivos    Int
  receitaPrevista   Decimal  @db.Decimal(14, 2)
  entregasPendentes Int
  recebidoNoMes     Decimal  @db.Decimal(14, 2)
  createdAt         DateTime @default(now())

  @@map("dashboard_snapshot")
}

// ─────────────────────────────────────────────────────────────
// Suporte (Onda 5f)
// ─────────────────────────────────────────────────────────────

enum StatusTicket {
  aberto
  em_atendimento
  resolvido
}

model TicketSuporte {
  id        String       @id @default(cuid())
  titulo    String
  descricao String
  status    StatusTicket @default(aberto)
  autorId   String
  autor     User         @relation("TicketAutor", fields: [autorId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  mensagens TicketMensagem[]

  @@index([status])
  @@map("ticket_suporte")
}

model TicketMensagem {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    TicketSuporte @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User          @relation("TicketMensagemAutor", fields: [autorId], references: [id])
  texto     String        @default("")
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_mensagem")
}

// ─────────────────────────────────────────────────────────────
// Planejamento & Recursos (Onda 5)
// ─────────────────────────────────────────────────────────────

/// Tarefa da EAP (WBS) de um projeto — hierárquica, com datas previstas
/// (plano atual) e de linha de base (snapshot p/ o gantt de linha dupla).
model EapTarefa {
  id             String      @id @default(cuid())
  projetoId      String
  projeto        Projeto     @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         EapTarefa?  @relation("EapFilhas", fields: [parentId], references: [id], onDelete: Cascade)
  filhas         EapTarefa[] @relation("EapFilhas")
  disciplinaId   String?
  disciplina     Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: SetNull)
  nome           String
  ordem          Int         @default(0)
  inicioPrevisto DateTime    @db.Date
  fimPrevisto    DateTime    @db.Date
  inicioBaseline DateTime?   @db.Date
  fimBaseline    DateTime?   @db.Date
  progresso      Int         @default(0)

  predecessoras EapDependencia[] @relation("EapDependente")
  sucessoras    EapDependencia[] @relation("EapPredecessora")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projetoId])
  @@index([parentId])
  @@map("eap_tarefa")
}

/// Dependência FS entre tarefas da EAP (predecessora termina antes da sucessora iniciar).
model EapDependencia {
  id             String    @id @default(cuid())
  tarefaId       String
  tarefa         EapTarefa @relation("EapDependente", fields: [tarefaId], references: [id], onDelete: Cascade)
  predecessoraId String
  predecessora   EapTarefa @relation("EapPredecessora", fields: [predecessoraId], references: [id], onDelete: Cascade)

  @@unique([tarefaId, predecessoraId])
  @@index([predecessoraId])
  @@map("eap_dependencia")
}

/// Pessoa como recurso de planejamento (multiplicador de capacidade, custo/hora, cor).
model Recurso {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  capacidade Decimal  @default(1.0) @db.Decimal(4, 2)
  custoHora  Decimal? @db.Decimal(10, 2)
  cor        String   @default("#576980")
  ativo      Boolean  @default(true)

  alocacoes Alocacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recurso")
}

/// Alocação de um recurso a um projeto (percentual + período opcional). Base da matriz de recursos.
model Alocacao {
  id         String    @id @default(cuid())
  recursoId  String
  recurso    Recurso   @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  projetoId  String
  projeto    Projeto   @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  percentual Int       @default(100)
  inicio     DateTime? @db.Date
  fim        DateTime? @db.Date
  observacao String?

  createdAt DateTime @default(now())

  @@unique([recursoId, projetoId])
  @@index([projetoId])
  @@map("alocacao")
}

// ─────────────────────────────────────────────────────────────
// Comercial / CRM (Onda 4)
// ─────────────────────────────────────────────────────────────

/// Etapa do funil de vendas (Kanban configurável).
model FunilEtapa {
  id    String  @id @default(cuid())
  nome  String  @unique
  ordem Int     @default(0)
  cor   String?
  ativo Boolean @default(true)

  leads Lead[]

  @@map("funil_etapa")
}

model Lead {
  id            String     @id @default(cuid())
  nome          String
  contato       String?
  email         String?
  telefone      String?
  origem        String?
  valorEstimado Decimal?   @db.Decimal(14, 2)
  etapaId       String
  etapa         FunilEtapa @relation(fields: [etapaId], references: [id])
  /// Preenchido quando o lead é convertido em cliente.
  clienteId     String?
  cliente       Cliente?   @relation(fields: [clienteId], references: [id])
  observacoes   String?
  arquivado     Boolean    @default(false)

  atividades AtividadeLead[]
  propostas  Proposta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([etapaId, arquivado])
  @@map("lead")
}

model AtividadeLead {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  nota      String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("atividade_lead")
}

model MetaComercial {
  id    String  @id @default(cuid())
  ano   Int
  mes   Int
  valor Decimal @db.Decimal(14, 2)

  @@unique([ano, mes])
  @@map("meta_comercial")
}

/// Tabela de preço por m² por disciplina (preços automáticos da proposta).
model TabelaPreco {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)

  itens ItemTabelaPreco[]

  @@map("tabela_preco")
}

model ItemTabelaPreco {
  id         String      @id @default(cuid())
  tabelaId   String
  tabela     TabelaPreco @relation(fields: [tabelaId], references: [id], onDelete: Cascade)
  disciplina String
  valorM2    Decimal     @db.Decimal(12, 2)

  @@unique([tabelaId, disciplina])
  @@map("item_tabela_preco")
}

enum StatusProposta {
  rascunho
  enviada
  aceita
  recusada
}

model PropostaSequencia {
  ano    Int @id
  ultimo Int @default(0)

  @@map("proposta_sequencia")
}

model Proposta {
  id         String         @id @default(cuid())
  ano        Int
  sequencial Int
  /// Número de exibição: PR-260001
  numero     String         @unique
  titulo     String
  clienteId  String
  cliente    Cliente        @relation(fields: [clienteId], references: [id])
  leadId     String?
  lead       Lead?          @relation(fields: [leadId], references: [id])
  status     StatusProposta @default(rascunho)
  areaM2     Decimal?       @db.Decimal(12, 2)
  validade   DateTime?      @db.Date
  observacoes String?
  /// Token do link público (/a/proposta/[token]).
  token      String         @unique
  autorId    String
  autor      User           @relation("PropostaAutor", fields: [autorId], references: [id])
  /// Projeto gerado no aceite.
  projetoId  String?        @unique
  projeto    Projeto?       @relation(fields: [projetoId], references: [id])

  enviadaEm DateTime?
  aceitaEm  DateTime?

  itens         PropostaItem[]
  condicoes     PropostaCondicao[]
  versoes       PropostaVersao[]
  visualizacoes PropostaVisualizacao[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ano, sequencial])
  @@index([status])
  @@index([clienteId])
  @@map("proposta")
}

model PropostaItem {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  disciplina String
  descricao  String?
  valor      Decimal  @db.Decimal(14, 2)
  ordem      Int      @default(0)

  @@index([propostaId])
  @@map("proposta_item")
}

enum TipoCondicao {
  percentual
  valor
}

model PropostaCondicao {
  id         String       @id @default(cuid())
  propostaId String
  proposta   Proposta     @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  descricao  String
  tipo       TipoCondicao @default(percentual)
  valor      Decimal      @db.Decimal(14, 2)
  ordem      Int          @default(0)

  @@index([propostaId])
  @@map("proposta_condicao")
}

/// Snapshot da proposta a cada salvar (itens+condições serializados).
model PropostaVersao {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  numero     Int
  snapshot   Json
  autorId    String
  autor      User     @relation("PropostaVersaoAutor", fields: [autorId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([propostaId, numero])
  @@map("proposta_versao")
}

/// Abertura registrada pelo pixel do link público.
model PropostaVisualizacao {
  id         String   @id @default(cuid())
  propostaId String
  proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([propostaId])
  @@map("proposta_visualizacao")
}

// ─────────────────────────────────────────────────────────────
// Estúdio de Documentos (Onda D) — modelos de relatório em bandas
// ─────────────────────────────────────────────────────────────

enum TipoDocumento {
  relatorio
  proposta
  contrato
  recibo
  holerite
  outro
}

/// Modelo (template) de documento. Layout em bandas no schemaJson.
model DocumentoModelo {
  id        String        @id @default(cuid())
  nome      String
  descricao String?
  tipo      TipoDocumento @default(relatorio)
  /// Fonte de dados padrão (id do registry em modules/documentos/fontes.ts).
  fonte     String?
  schemaJson Json
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  versoes DocumentoModeloVersao[]

  @@index([tipo, ativo])
  @@map("documento_modelo")
}

/// Histórico de versões (criada a cada salvar).
model DocumentoModeloVersao {
  id         String          @id @default(cuid())
  modeloId   String
  modelo     DocumentoModelo @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  numero     Int
  schemaJson Json
  autorId    String
  autor      User            @relation(fields: [autorId], references: [id])
  createdAt  DateTime        @default(now())

  @@unique([modeloId, numero])
  @@map("documento_modelo_versao")
}

/// Documento gerado e persistido (histórico imutável do que foi produzido/enviado).
/// Snapshot do schema + dados resolvidos no momento da geração; nomes guardados p/ sobreviver à exclusão.
model DocumentoGerado {
  id             String   @id @default(cuid())
  modeloId       String?
  modeloNome     String
  fonte          String?
  params         Json
  schemaSnapshot Json
  dadosSnapshot  Json
  geradoPorId    String
  geradoPorNome  String
  createdAt      DateTime @default(now())

  @@index([modeloId])
  @@index([createdAt])
  @@map("documento_gerado")
}

// ─────────────────────────────────────────────────────────────
// RH — Folha CLT, Onboarding, NF de PJ (Onda 3e/3f/3g)
// ─────────────────────────────────────────────────────────────

enum TipoRubrica {
  provento
  desconto
}

/// Catálogo de rubricas da folha (salário, VT, INSS, IRRF…).
model RubricaFolha {
  id    String      @id @default(cuid())
  nome  String      @unique
  tipo  TipoRubrica
  ordem Int         @default(0)
  ativo Boolean     @default(true)

  itens HoleriteItem[]

  @@map("rubrica_folha")
}

/// Faixa de encargo da folha (INSS/IRRF). Sem valores embutidos — configurável em Configurações.
model EncargoFaixa {
  id       String  @id @default(cuid())
  tipo     String // "inss" | "irrf"
  limite   Decimal @db.Decimal(14, 2) // limite superior da faixa
  aliquota Decimal @db.Decimal(6, 3) // %
  deduzir  Decimal @default(0) @db.Decimal(14, 2) // parcela a deduzir (IRRF)
  ordem    Int     @default(0)

  @@index([tipo, ordem])
  @@map("encargo_faixa")
}

/// Dependente de um colaborador (p/ dedução de IRRF e cadastro de RH).
model Dependente {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome       String
  nascimento DateTime? @db.Date
  parentesco String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("dependente")
}

/// Prancha (folha técnica) de uma disciplina — código, título, revisão, escala.
model Prancha {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  codigo       String
  titulo       String
  revisao      String?
  escala       String?
  ordem        Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([disciplinaId])
  @@map("prancha")
}

/// Feriado (cadastro p/ ponto/escala/banco de horas). Data única.
model Feriado {
  id        String   @id @default(cuid())
  data      DateTime @unique @db.Date
  nome      String
  tipo      String   @default("nacional") // nacional | estadual | municipal
  createdAt DateTime @default(now())

  @@map("feriado")
}

/// Comentário de tarefa (texto e/ou anexo).
model TarefaComentario {
  id        String   @id @default(cuid())
  tarefaId  String
  tarefa    Tarefa   @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation("TarefaComentarioAutor", fields: [autorId], references: [id])
  texto     String   @default("")
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime @default(now())

  @@index([tarefaId])
  @@map("tarefa_comentario")
}

/// Habilidade/competência (catálogo).
model Habilidade {
  id       String           @id @default(cuid())
  nome     String           @unique
  usuarios UserHabilidade[]

  @@map("habilidade")
}

/// Vínculo colaborador × habilidade.
model UserHabilidade {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  habilidadeId String
  habilidade   Habilidade @relation(fields: [habilidadeId], references: [id], onDelete: Cascade)

  @@unique([userId, habilidadeId])
  @@map("user_habilidade")
}

/// Serviço terceirizado contratado para um projeto (fornecedor externo).
model ServicoTerceirizado {
  id           String      @id @default(cuid())
  projetoId    String
  projeto      Projeto     @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  fornecedorId String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  descricao    String
  valor        Decimal?    @db.Decimal(14, 2)
  status       String      @default("contratado") // contratado | concluido | cancelado
  createdAt    DateTime    @default(now())

  @@index([projetoId])
  @@map("servico_terceirizado")
}

enum StatusFolha {
  aberta
  fechada
}

model FolhaPagamento {
  id        String      @id @default(cuid())
  ano       Int
  mes       Int // 1-12
  status    StatusFolha @default(aberta)
  fechadaEm DateTime?
  /// Lançamento de despesa (2.03) criado ao fechar.
  lancamentoId String?  @unique

  holerites Holerite[]
  createdAt DateTime   @default(now())

  @@unique([ano, mes])
  @@map("folha_pagamento")
}

model Holerite {
  id        String         @id @default(cuid())
  folhaId   String
  folha     FolhaPagamento @relation(fields: [folhaId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  enviadoEm DateTime?

  itens HoleriteItem[]

  @@unique([folhaId, userId])
  @@map("holerite")
}

model HoleriteItem {
  id         String        @id @default(cuid())
  holeriteId String
  holerite   Holerite      @relation(fields: [holeriteId], references: [id], onDelete: Cascade)
  rubricaId  String?
  rubrica    RubricaFolha? @relation(fields: [rubricaId], references: [id])
  descricao  String
  tipo       TipoRubrica
  valor      Decimal       @db.Decimal(12, 2)

  @@index([holeriteId])
  @@map("holerite_item")
}

model OnboardingTemplate {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)

  itens     OnboardingTemplateItem[]
  processos OnboardingProcesso[]

  @@map("onboarding_template")
}

model OnboardingTemplateItem {
  id         String             @id @default(cuid())
  templateId String
  template   OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  descricao  String
  ordem      Int                @default(0)

  @@index([templateId])
  @@map("onboarding_template_item")
}

/// Checklist de admissão de um colaborador (1 por usuário).
model OnboardingProcesso {
  id         String              @id @default(cuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String?
  template   OnboardingTemplate? @relation(fields: [templateId], references: [id])
  createdAt  DateTime            @default(now())

  itens OnboardingItem[]

  @@map("onboarding_processo")
}

model OnboardingItem {
  id          String             @id @default(cuid())
  processoId  String
  processo    OnboardingProcesso @relation(fields: [processoId], references: [id], onDelete: Cascade)
  descricao   String
  ordem       Int                @default(0)
  concluido   Boolean            @default(false)
  concluidoEm DateTime?

  @@index([processoId])
  @@map("onboarding_item")
}

enum StatusNF {
  enviada
  aprovada
  rejeitada
}

/// Nota fiscal enviada por PJ/freelancer para faturar pagamentos.
model NotaFiscalPJ {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("NfUser", fields: [userId], references: [id])
  numero      String?
  valor       Decimal  @db.Decimal(12, 2)
  /// Caminho relativo a STORAGE_BASE_PATH.
  arquivoPath String
  arquivoNome String
  status      StatusNF @default(enviada)
  observacao  String?

  validadoPorId String?
  validadoPor   User?     @relation("NfValidador", fields: [validadoPorId], references: [id])
  validadoEm    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@map("nota_fiscal_pj")
}

enum PacoteUpload {
  A // plantas / memoriais
  B // backup do software
  OUTROS // formatos não suportados
}

model Upload {
  id           String       @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina   @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  pacote       PacoteUpload
  nomeArquivo  String
  /// Caminho relativo a STORAGE_BASE_PATH (nunca absoluto).
  caminho      String
  hashSha256   String
  tamanho      Int
  mimeType     String?
  versao       Int          @default(1)

  validado     Boolean   @default(false)
  validadoPorId String?
  validadoPor   User?    @relation("UploadValidador", fields: [validadoPorId], references: [id])
  validadoEm   DateTime?

  autorId   String
  autor     User     @relation("UploadAutor", fields: [autorId], references: [id])
  createdAt DateTime @default(now())

  @@index([disciplinaId, pacote])
  @@index([autorId])
  @@map("upload")
}

enum StatusPagamento {
  pendente
  pago
  cancelado
}

/// Pagamento ao projetista por entrega validada. Na Onda 2 será
/// vinculado a um Lançamento financeiro (campo lancamentoId).
model PagamentoProjetista {
  id               String          @id @default(cuid())
  disciplinaId     String
  disciplina       Disciplina      @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  projetistaId     String
  projetista       User            @relation("PagamentoProjetista", fields: [projetistaId], references: [id])
  valor            Decimal         @db.Decimal(12, 2)
  tipoProfissional String // role do projetista no momento da liberação
  status           StatusPagamento @default(pendente)
  liberadoEm       DateTime        @default(now())
  pagoEm           DateTime?
  observacao       String?
  lancamentoId     String? // vínculo futuro com o Financeiro (Onda 2)

  createdAt DateTime @default(now())

  @@index([projetistaId, status])
  @@index([disciplinaId])
  @@map("pagamento_projetista")
}
