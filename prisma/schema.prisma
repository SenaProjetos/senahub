generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Identidade & acesso
// ─────────────────────────────────────────────────────────────

enum Role {
  admin
  supervisor
  administrativo
  clt
  estagiario
  projetista_pj
  freelancer
  cliente
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?

  // Campos de domínio
  role               Role       @default(cliente)
  ativo              Boolean    @default(true)
  mustChangePassword Boolean    @default(false)
  chatStatus         ChatStatus @default(disponivel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  auditLogs AuditLog[]
  resetSolicitacoes SolicitacaoResetSenha[]

  projetosMembro       ProjetoMembro[]
  disciplinasResponsavel DisciplinaResponsavel[]
  revisoes             RevisaoDisciplina[]
  uploadsAutor         Upload[]              @relation("UploadAutor")
  uploadsValidados     Upload[]              @relation("UploadValidador")
  pagamentos           PagamentoProjetista[] @relation("PagamentoProjetista")
  socio                Socio?
  lancamentosAutor     Lancamento[]          @relation("LancamentoAutor")
  canaisMembro         CanalMembro[]
  mensagens            Mensagem[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Pedido de reset de senha (admin reinicia pela tela de usuários).
model SolicitacaoResetSenha {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resolvida Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([resolvida])
  @@map("solicitacao_reset_senha")
}

// ─────────────────────────────────────────────────────────────
// Permissões finas (recurso:ação), configuráveis em runtime
// ─────────────────────────────────────────────────────────────

model Permissao {
  id      String  @id @default(cuid())
  role    Role
  recurso String
  acao    String
  permitido Boolean @default(true)

  @@unique([role, recurso, acao])
  @@index([role])
  @@map("permissao")
}

// ─────────────────────────────────────────────────────────────
// Auditoria (registro imutável de toda mutação)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  modulo     String
  acao       String
  tipo       String   @default("acao") // acao | login | erro
  resultado  String   @default("sucesso") // sucesso | falha | bloqueado
  entidade   String?
  entidadeId String?
  detalhe    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([modulo])
  @@index([createdAt])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// Notificações (sininho interno) + Web Push
// ─────────────────────────────────────────────────────────────

model Notificacao {
  id        String   @id @default(cuid())
  userId    String
  titulo    String
  corpo     String?
  href      String?
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lida])
  @@map("notificacao")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscription")
}

// ─────────────────────────────────────────────────────────────
// Configuração geral do sistema (chave/valor)
// ─────────────────────────────────────────────────────────────

model ConfigSistema {
  chave     String   @id
  valor     Json
  updatedAt DateTime @updatedAt

  @@map("config_sistema")
}

// ─────────────────────────────────────────────────────────────
// Clientes (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoPessoa {
  PF
  PJ
}

model Cliente {
  id           String     @id @default(cuid())
  tipo         TipoPessoa @default(PJ)
  nome         String // nome (PF) ou razão social (PJ)
  nomeFantasia String?
  documento    String? // CPF ou CNPJ
  email        String?
  telefone     String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?

  observacoes String?
  ativo       Boolean  @default(true)

  // Login externo opcional do cliente (criado sob demanda).
  usuarioId String? @unique

  contatos    ContatoCliente[]
  projetos    Projeto[]
  lancamentos Lancamento[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([ativo])
  @@index([nome])
  @@map("cliente")
}

model ContatoCliente {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  nome      String
  cargo     String?
  email     String?
  telefone  String?
  principal Boolean @default(false)

  @@index([clienteId])
  @@map("contato_cliente")
}

// ─────────────────────────────────────────────────────────────
// Projetos & Disciplinas (Onda 1)
// ─────────────────────────────────────────────────────────────

enum TipoProjeto {
  particular
  licitacao
}

enum SituacaoProjeto {
  em_andamento
  concluido
  arquivado
  cancelado
}

enum StatusDisciplina {
  aguardando
  em_andamento
  em_revisao
  entregue
  aprovado
}

/// Catálogo configurável de disciplinas (Estrutural, Hidráulica…).
model DisciplinaCatalogo {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  @@map("disciplina_catalogo")
}

/// Sequência atômica do número AAXXXX por ano.
model ProjetoSequencia {
  ano    Int @id
  ultimo Int @default(0)

  @@map("projeto_sequencia")
}

model Projeto {
  id          String          @id @default(cuid())
  ano         Int
  sequencial  Int
  /// Código de exibição AAXXXX (ex.: 260142).
  codigo      String          @unique
  tipo        TipoProjeto     @default(particular)
  situacao    SituacaoProjeto @default(em_andamento)
  nome        String
  descricao   String?
  clienteId   String
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  areaM2      Decimal?        @db.Decimal(12, 2)
  endereco    String?
  prazoFinal  DateTime?

  disciplinas Disciplina[]
  membros     ProjetoMembro[]
  inputs      InputProjeto[]
  linkInput   LinkPublicoInput?
  lancamentos Lancamento[]
  canais      Canal[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([ano, sequencial])
  @@index([clienteId])
  @@index([situacao])
  @@map("projeto")
}

/// Campo de input do projeto (pergunta + resposta do cliente).
model InputProjeto {
  id         String   @id @default(cuid())
  projetoId  String
  projeto    Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplina String? // null = geral; senão nome da disciplina
  pergunta   String
  resposta   String?
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projetoId])
  @@map("input_projeto")
}

/// Link público (por token) para o cliente preencher os inputs sem login.
model LinkPublicoInput {
  id        String   @id @default(cuid())
  projetoId String   @unique
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  token     String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("link_publico_input")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Cadastros base (Onda 2a)
// ─────────────────────────────────────────────────────────────

enum TipoCategoria {
  receita
  despesa
}

/// Plano de contas hierárquico (código ex.: "2.01").
model CategoriaFinanceira {
  id     String        @id @default(cuid())
  codigo String        @unique
  nome   String
  tipo   TipoCategoria
  paiId  String?
  pai    CategoriaFinanceira?  @relation("CategoriaFilhas", fields: [paiId], references: [id])
  filhas CategoriaFinanceira[] @relation("CategoriaFilhas")
  ordem  Int           @default(0)
  ativo  Boolean       @default(true)

  lancamentos Lancamento[]
  regras      RegraCategorizacao[]

  @@index([tipo, ativo])
  @@map("categoria_financeira")
}

model CentroCusto {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos Lancamento[]

  @@map("centro_custo")
}

enum TipoContaBancaria {
  corrente
  poupanca
  caixa
  investimento
}

model ContaBancaria {
  id           String            @id @default(cuid())
  nome         String
  tipo         TipoContaBancaria @default(corrente)
  banco        String?
  agencia      String?
  numero       String?
  saldoInicial Decimal           @default(0) @db.Decimal(14, 2)
  padrao       Boolean           @default(false)
  ativo        Boolean           @default(true)
  ordem        Int               @default(0)

  lancamentos Lancamento[]
  extratos    ExtratoBancario[]
  transacoes  TransacaoBancaria[]

  @@map("conta_bancaria")
}

model FormaPagamento {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
  ordem Int     @default(0)

  lancamentos Lancamento[]

  @@map("forma_pagamento")
}

model Fornecedor {
  id          String     @id @default(cuid())
  tipo        TipoPessoa @default(PJ)
  nome        String
  documento   String?
  email       String?
  telefone    String?
  /// Tipo de serviço (topografia, sondagem, ensaios…)
  servico     String?
  observacoes String?
  ativo       Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lancamentos Lancamento[]

  @@index([ativo])
  @@map("fornecedor")
}

model Socio {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  percentual Decimal  @db.Decimal(5, 2)
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("socio")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Lançamentos (ledger) + contas a pagar/receber (Onda 2b)
// ─────────────────────────────────────────────────────────────

enum TipoLancamento {
  receita
  despesa
}

enum StatusLancamento {
  previsto // conta a pagar/receber em aberto
  confirmado // pago/recebido (entra no caixa e na DRE)
  cancelado
}

/// Lançamento financeiro. previsto = conta a pagar/receber; confirmado = realizado.
model Lancamento {
  id        String           @id @default(cuid())
  tipo      TipoLancamento
  descricao String
  valor     Decimal          @db.Decimal(14, 2)
  /// Valor efetivamente pago/recebido (parcial). Se null, considera `valor`.
  valorEfetivo Decimal?      @db.Decimal(14, 2)
  status    StatusLancamento @default(previsto)

  /// Competência/realização. `vencimento` para previstos; `dataConfirmacao` ao realizar.
  data            DateTime  @db.Date
  vencimento      DateTime? @db.Date
  dataConfirmacao DateTime? @db.Date

  categoriaId String
  categoria   CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  centroId    String?
  centro      CentroCusto?        @relation(fields: [centroId], references: [id])
  contaId     String?
  conta       ContaBancaria?      @relation(fields: [contaId], references: [id])
  formaId     String?
  forma       FormaPagamento?     @relation(fields: [formaId], references: [id])
  projetoId   String?
  projeto     Projeto?            @relation(fields: [projetoId], references: [id])
  fornecedorId String?
  fornecedor   Fornecedor?        @relation(fields: [fornecedorId], references: [id])
  clienteId   String?
  cliente     Cliente?            @relation(fields: [clienteId], references: [id])

  observacao       String?
  recorrenciaGrupo String?
  /// Vínculo com a folha de projetistas (Onda 2c).
  pagamentoProjetistaId String? @unique

  autorId String
  autor   User   @relation("LancamentoAutor", fields: [autorId], references: [id])

  transacao TransacaoBancaria?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, status])
  @@index([vencimento])
  @@index([data])
  @@index([projetoId])
  @@map("lancamento")
}

// ─────────────────────────────────────────────────────────────
// Financeiro — Conciliação bancária (OFX) (Onda 2d)
// ─────────────────────────────────────────────────────────────

model ExtratoBancario {
  id          String              @id @default(cuid())
  contaId     String
  conta       ContaBancaria       @relation(fields: [contaId], references: [id])
  nomeArquivo String?
  importadoEm DateTime            @default(now())
  transacoes  TransacaoBancaria[]

  @@index([contaId])
  @@map("extrato_bancario")
}

model TransacaoBancaria {
  id          String          @id @default(cuid())
  extratoId   String
  extrato     ExtratoBancario @relation(fields: [extratoId], references: [id], onDelete: Cascade)
  contaId     String
  conta       ContaBancaria   @relation(fields: [contaId], references: [id])
  /// Identificador único da transação no OFX (dedup).
  fitid       String
  data        DateTime        @db.Date
  /// Positivo = entrada, negativo = saída.
  valor       Decimal         @db.Decimal(14, 2)
  descricao   String
  conciliado  Boolean         @default(false)
  /// Lançamento ao qual esta transação foi conciliada.
  lancamentoId String?        @unique
  lancamento   Lancamento?    @relation(fields: [lancamentoId], references: [id])

  createdAt DateTime @default(now())

  @@unique([contaId, fitid])
  @@index([contaId, conciliado])
  @@map("transacao_bancaria")
}

/// Regra de auto-categorização: descrição que casa → categoria sugerida.
model RegraCategorizacao {
  id          String              @id @default(cuid())
  termo       String
  categoriaId String
  categoria   CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  ativo       Boolean             @default(true)

  @@map("regra_categorizacao")
}

// ─────────────────────────────────────────────────────────────
// Chat interno (Onda 3a)
// ─────────────────────────────────────────────────────────────

enum TipoCanal {
  geral
  projeto
  disciplina
  dm
}

enum ChatStatus {
  disponivel
  ocupado
  reuniao
}

model Canal {
  id           String      @id @default(cuid())
  tipo         TipoCanal
  nome         String?
  projetoId    String?
  projeto      Projeto?    @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  disciplinaId String?
  disciplina   Disciplina? @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)

  membros   CanalMembro[]
  mensagens Mensagem[]
  createdAt DateTime      @default(now())

  @@index([tipo])
  @@index([projetoId])
  @@index([disciplinaId])
  @@map("canal")
}

model CanalMembro {
  id         String    @id @default(cuid())
  canalId    String
  canal      Canal     @relation(fields: [canalId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?

  @@unique([canalId, userId])
  @@index([userId])
  @@map("canal_membro")
}

model Mensagem {
  id        String   @id @default(cuid())
  canalId   String
  canal     Canal    @relation(fields: [canalId], references: [id], onDelete: Cascade)
  autorId   String
  autor     User     @relation(fields: [autorId], references: [id])
  conteudo  String
  fixada    Boolean  @default(false)
  anexoPath String?
  anexoNome String?
  anexoMime String?
  createdAt DateTime @default(now())
  editedAt  DateTime?

  @@index([canalId, createdAt])
  @@map("mensagem")
}

model ProjetoMembro {
  id        String  @id @default(cuid())
  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  papel     String? // ex.: coordenador, projetista

  @@unique([projetoId, userId])
  @@index([userId])
  @@map("projeto_membro")
}

model Disciplina {
  id        String           @id @default(cuid())
  projetoId String
  projeto   Projeto          @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  nome      String
  status    StatusDisciplina @default(aguardando)
  prazo     DateTime?
  /// Valor a pagar ao(s) projetista(s) por esta entrega.
  valor     Decimal?         @db.Decimal(12, 2)
  ordem     Int              @default(0)

  responsaveis DisciplinaResponsavel[]
  revisoes     RevisaoDisciplina[]
  uploads      Upload[]
  pagamentos   PagamentoProjetista[]
  canais       Canal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projetoId])
  @@index([status])
  @@map("disciplina")
}

model DisciplinaResponsavel {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  @@unique([disciplinaId, userId])
  @@index([userId])
  @@map("disciplina_responsavel")
}

/// Log imutável de revisões (RV00, RV01…) por disciplina.
model RevisaoDisciplina {
  id           String     @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  numero       Int // 0 = RV00
  motivo       String?
  autorId      String
  autor        User       @relation(fields: [autorId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([disciplinaId, numero])
  @@index([disciplinaId])
  @@map("revisao_disciplina")
}

// ─────────────────────────────────────────────────────────────
// Uploads & Validação → Pagamento (Onda 1)
// ─────────────────────────────────────────────────────────────

enum PacoteUpload {
  A // plantas / memoriais
  B // backup do software
  OUTROS // formatos não suportados
}

model Upload {
  id           String       @id @default(cuid())
  disciplinaId String
  disciplina   Disciplina   @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  pacote       PacoteUpload
  nomeArquivo  String
  /// Caminho relativo a STORAGE_BASE_PATH (nunca absoluto).
  caminho      String
  hashSha256   String
  tamanho      Int
  mimeType     String?
  versao       Int          @default(1)

  validado     Boolean   @default(false)
  validadoPorId String?
  validadoPor   User?    @relation("UploadValidador", fields: [validadoPorId], references: [id])
  validadoEm   DateTime?

  autorId   String
  autor     User     @relation("UploadAutor", fields: [autorId], references: [id])
  createdAt DateTime @default(now())

  @@index([disciplinaId, pacote])
  @@index([autorId])
  @@map("upload")
}

enum StatusPagamento {
  pendente
  pago
  cancelado
}

/// Pagamento ao projetista por entrega validada. Na Onda 2 será
/// vinculado a um Lançamento financeiro (campo lancamentoId).
model PagamentoProjetista {
  id               String          @id @default(cuid())
  disciplinaId     String
  disciplina       Disciplina      @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
  projetistaId     String
  projetista       User            @relation("PagamentoProjetista", fields: [projetistaId], references: [id])
  valor            Decimal         @db.Decimal(12, 2)
  tipoProfissional String // role do projetista no momento da liberação
  status           StatusPagamento @default(pendente)
  liberadoEm       DateTime        @default(now())
  pagoEm           DateTime?
  observacao       String?
  lancamentoId     String? // vínculo futuro com o Financeiro (Onda 2)

  createdAt DateTime @default(now())

  @@index([projetistaId, status])
  @@index([disciplinaId])
  @@map("pagamento_projetista")
}
