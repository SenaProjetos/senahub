{
  "name": "senahub",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:server": "tsx watch --tsconfig tsconfig.server.json server.ts --dev",
    "build": "next build --turbopack",
    "start": "tsx --tsconfig tsconfig.server.json server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --tsconfig tsconfig.server.json prisma/seed.ts",
    "seed:demo": "tsx --tsconfig tsconfig.server.json scripts/seed-demo.ts",
    "admin:reset-senha": "tsx --tsconfig tsconfig.server.json scripts/reset-admin-senha.ts",
    "notificar-deploy": "tsx --tsconfig tsconfig.server.json scripts/notificar-deploy.ts",
    "smoke:onda1": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda1.ts",
    "smoke:onda2": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda2.ts",
    "smoke:onda3efg": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda3efg.ts",
    "smoke:onda4": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda4.ts",
    "smoke:onda5": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda5.ts",
    "smoke:onda3": "tsx --tsconfig tsconfig.server.json scripts/smoke-onda3.ts",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:dry": "commit-and-tag-version --dry-run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@thatopen/components": "3.4.6",
    "@thatopen/fragments": "3.4.6",
    "archiver": "^8.0.0",
    "better-auth": "^1.6.16",
    "camera-controls": "3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.3",
    "puppeteer-core": "^24.43.1",
    "qrcode-generator": "^2.0.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "0.185.1",
    "tw-animate-css": "^1.4.0",
    "web-ifc": "0.0.77",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^8.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.185.1",
    "@types/web-push": "^3.6.4",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
